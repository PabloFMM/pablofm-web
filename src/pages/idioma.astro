---
import Layout from "@/layouts/Layout.astro";

const levels = [
  {
    n: 1,
    name: "Business",
    subtitle: "Pure operational language. No metaphors.",
    color: "#6b7280",
    bg: "bg-[#6b7280]/8",
    border: "border-[#6b7280]/25",
    dot: "bg-[#6b7280]",
    who: "Traditional companies, corporate teams, skeptical C-suites.",
    feel: "\"This is a work management system with structured documentation and AI agents.\"",
  },
  {
    n: 3,
    name: "Functional",
    subtitle: "Light metaphors. Familiar structure with a distinct voice.",
    color: "#fbbf24",
    bg: "bg-[#fbbf24]/8",
    border: "border-[#fbbf24]/25",
    dot: "bg-[#fbbf24]",
    who: "Agencies, creative studios, scale-ups with culture already.",
    feel: "\"We run initiatives through guilds, with agents that keep institutional memory alive.\"",
  },
  {
    n: 5,
    name: "Mixed",
    subtitle: "Half-narrative. Familiar enough to onboard fast, interesting enough to retain.",
    color: "#34d399",
    bg: "bg-[#34d399]/8",
    border: "border-[#34d399]/25",
    dot: "bg-[#34d399]",
    who: "Tech startups, DAOs, companies building culture intentionally.",
    feel: "\"Our missions run through Knowledge Leads and Innovation Leads, tracked in the Archive.\"",
  },
  {
    n: 7,
    name: "Narrative",
    subtitle: "Rich vocabulary. The system has character.",
    color: "#a78bfa",
    bg: "bg-[#a78bfa]/8",
    border: "border-[#a78bfa]/25",
    dot: "bg-[#a78bfa]",
    who: "Gaming companies, Web3 teams, organizations that want meaning at work.",
    feel: "\"Exégetas and Alquimistas run missions together, reporting to the Council.\"",
  },
  {
    n: 10,
    name: "Numinia",
    subtitle: "Full immersion. The city is the system.",
    color: "#2dd4bf",
    bg: "bg-[#2dd4bf]/8",
    border: "border-[#2dd4bf]/25",
    dot: "bg-[#2dd4bf]",
    who: "Numen Games. Organizations ready for a complete narrative operating system.",
    feel: "\"The Guardián de las Puertas runs the Dark Council. The Oráculos govern from the Archive Summa.\"",
  },
];

const vocab = [
  {
    category: "Agents & Roles",
    rows: [
      { concept: "Executive", b1: "Executive", f3: "Founder", m5: "Council Lead", n7: "Arconte", num10: "Oráculo" },
      { concept: "Operations Lead", b1: "Head of Operations", f3: "Operations Lead", m5: "Operations Lead", n7: "Centinela", num10: "Centinela" },
      { concept: "CTO / Innovation", b1: "CTO / Head of Product", f3: "Innovation Lead", m5: "Innovation Lead", n7: "Alquimista", num10: "Alquimista" },
      { concept: "Chief of Staff / Knowledge", b1: "Chief of Staff", f3: "Knowledge Lead", m5: "Knowledge Lead", n7: "Exégeta", num10: "Exégeta" },
      { concept: "COO / Business", b1: "Head of Business", f3: "Business Lead", m5: "Business Lead", n7: "Procurador", num10: "Procurador" },
      { concept: "AI Orchestration", b1: "AI Orchestration Layer", f3: "System Intelligence", m5: "System Intelligence", n7: "Procyon", num10: "Procyon" },
      { concept: "AI Agent", b1: "AI Agent", f3: "Digital Coworker", m5: "Digital Agent", n7: "Agente Digital", num10: "Agente Digital" },
      { concept: "New member", b1: "Onboarding", f3: "New member", m5: "Explorer", n7: "Nómada", num10: "Nómada" },
      { concept: "Team member", b1: "Team Member", f3: "Member", m5: "Citizen", n7: "Ciudadano", num10: "Ciudadano" },
      { concept: "Senior", b1: "Senior / Principal", f3: "Senior Member", m5: "Pilgrim", n7: "Peregrino", num10: "Peregrino" },
      { concept: "Expert", b1: "Expert / Principal", f3: "Expert", m5: "Expert", n7: "Vernáculo", num10: "Vernáculo" },
      { concept: "Director / Lead", b1: "Director / Lead", f3: "Lead", m5: "Archon", n7: "Arconte", num10: "Arconte" },
    ],
  },
  {
    category: "Structures",
    rows: [
      { concept: "Department / Team", b1: "Department", f3: "Team", m5: "Guild", n7: "Gremio", num10: "Gremio" },
      { concept: "Division / Area", b1: "Division", f3: "Area", m5: "Faction", n7: "Facción", num10: "Facción" },
      { concept: "Operations Center", b1: "Operations Center", f3: "Ops Center", m5: "CAO", n7: "CAO", num10: "CAO" },
      { concept: "System Blueprint", b1: "System Blueprint", f3: "System Map", m5: "Blueprint", n7: "Plano", num10: "Plano" },
      { concept: "Knowledge Base", b1: "Knowledge Base", f3: "Knowledge Base", m5: "Archive", n7: "Archivo", num10: "Archive Summa" },
      { concept: "Decision Record", b1: "Decision Record", f3: "Decision Record", m5: "Decision Stone", n7: "Decisión", num10: "Piedra del Camino" },
      { concept: "Report", b1: "Report", f3: "Report", m5: "Dispatch", n7: "Reporte", num10: "Reporte" },
      { concept: "Process / SOP", b1: "Process / SOP", f3: "Protocol", m5: "Protocol", n7: "Protocolo", num10: "Protocolo" },
    ],
  },
  {
    category: "Actions & Rituals",
    rows: [
      { concept: "Project / Initiative", b1: "Project", f3: "Initiative", m5: "Mission", n7: "Misión", num10: "Misión" },
      { concept: "Daily Standup", b1: "Daily Standup", f3: "Daily", m5: "Daily", n7: "Daily", num10: "Daily" },
      { concept: "Weekly Strategy", b1: "Weekly Strategy Meeting", f3: "Strategy Session", m5: "Council", n7: "Dark Council", num10: "Dark Council" },
      { concept: "Creative Session", b1: "Creative Session", f3: "Creative Session", m5: "Coven", n7: "Lunar Coven", num10: "Lunar Coven" },
      { concept: "Onboarding Workshop", b1: "Onboarding", f3: "Onboarding Workshop", m5: "Session Zero", n7: "Session Zero", num10: "Session Zero" },
      { concept: "Campaign / Program", b1: "Program", f3: "Campaign", m5: "Adventure", n7: "Aventura", num10: "Aventura" },
      { concept: "Quarter / Cycle", b1: "Quarter", f3: "Cycle", m5: "Season", n7: "Temporada", num10: "Temporada" },
    ],
  },
  {
    category: "System & Product",
    rows: [
      { concept: "Work Operating System", b1: "Work Operating System", f3: "Work OS", m5: "Narrative Work OS", n7: "Narrative Work OS", num10: "Narrative Work OS" },
      { concept: "The Organization", b1: "The Organization", f3: "The System", m5: "The City", n7: "Numinia", num10: "Numinia" },
      { concept: "Membership Token", b1: "Membership Token", f3: "Access Token", m5: "Prism Cell", n7: "Prism Cell", num10: "Prism Cell" },
      { concept: "Badge / Certificate", b1: "Badge", f3: "Achievement", m5: "Seal", n7: "Sello", num10: "Sello" },
    ],
  },
];

const colColors = ["#6b7280", "#fbbf24", "#34d399", "#a78bfa", "#2dd4bf"];
const colNames = ["Business 1", "Functional 3", "Mixed 5", "Narrative 7", "Numinia 10"];
---

<Layout
  title="Narrative Dial — Language System · Numen Games"
  description="Two dials. One system. Organizations choose their level of narrative and gamification. The NWOS speaks any language."
  canonicalPath="/idioma"
  activeNav="idioma"
>

  <!-- Hero -->
  <section class="pt-16 pb-12 border-b border-border">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="flex flex-wrap items-center gap-2 mb-6">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Numen Games · NWOS · Adaptability</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl text-foreground mb-4">Two Dials. One System.</h1>
      <p class="text-lg text-muted-foreground leading-relaxed">
        The Narrative Work OS speaks any language. Organizations choose how much narrative and how much gamification they want. The system is the same — the vocabulary adapts.
      </p>
    </div>
  </section>

  <!-- The two dials -->
  <section class="py-16 border-b border-border">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="mb-8 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">The two dials</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        <!-- Narrative dial -->
        <div class="rounded-2xl border border-accent/30 bg-accent/5 p-7">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">🎭</span>
            <div>
              <h2 class="font-display text-xl text-foreground">Narrative Dial</h2>
              <p class="font-mono text-[0.6rem] text-dim">1 → 10</p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-5">
            Controls vocabulary and semantic identity. At 1, it's a business tool. At 10, you're inside a living world.
          </p>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <span class="font-mono text-[0.6rem] text-[#6b7280]">1 — Business</span>
              <span class="font-mono text-[0.6rem] text-[#6b7280]">"Project Management"</span>
            </div>
            <div class="h-2 rounded-full bg-gradient-to-r from-[#6b7280] via-[#34d399] to-[#2dd4bf]"></div>
            <div class="flex items-center justify-between">
              <span class="font-mono text-[0.6rem] text-[#2dd4bf]">10 — Numinia</span>
              <span class="font-mono text-[0.6rem] text-[#2dd4bf]">"Misiones del Oráculo"</span>
            </div>
          </div>
        </div>

        <!-- Gamification dial -->
        <div class="rounded-2xl border border-border bg-card p-7">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">🎮</span>
            <div>
              <h2 class="font-display text-xl text-foreground">Gamification Dial</h2>
              <p class="font-mono text-[0.6rem] text-dim">1 → 10 · <span class="text-yellow">In design</span></p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-5">
            Controls game mechanics, progression, and reward systems. Independent from the narrative. A 1/10 narrative org can still have full gamification.
          </p>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <span class="font-mono text-[0.6rem] text-dim">1 — No mechanics</span>
              <span class="font-mono text-[0.6rem] text-dim">Just the OS</span>
            </div>
            <div class="h-2 rounded-full bg-gradient-to-r from-border to-border relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#fbbf24]/30 to-[#fbbf24]/60 animate-pulse"></div>
            </div>
            <div class="flex items-center justify-between">
              <span class="font-mono text-[0.6rem] text-yellow">10 — Full RPG</span>
              <span class="font-mono text-[0.6rem] text-yellow">Ranks, Prism Cells, Seals</span>
            </div>
          </div>
          <p class="font-mono text-[0.55rem] text-dim mt-4 italic">Gamification system design in progress — MIS-055</p>
        </div>
      </div>

      <!-- Both dials are independent -->
      <div class="mt-6 rounded-xl border border-border bg-card/50 p-5">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-3">The dials are independent</p>
        <div class="grid sm:grid-cols-3 gap-4 text-sm text-muted-foreground">
          <div>🏢 <strong class="text-foreground">Corp standard</strong><br/>Narrative 1 · Gamification 1<br/><span class="text-xs">Pure business tool</span></div>
          <div>🎮 <strong class="text-foreground">Gaming company</strong><br/>Narrative 4 · Gamification 9<br/><span class="text-xs">Gamified but business language</span></div>
          <div>🌒 <strong class="text-foreground">Numinia</strong><br/>Narrative 10 · Gamification TBD<br/><span class="text-xs">Full immersion</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- The 5 narrative levels -->
  <section class="py-16 border-b border-border">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="mb-8 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Narrative Dial — 5 levels</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>
      <div class="space-y-4">
        {levels.map((level) => (
          <div class={`rounded-xl border ${level.border} ${level.bg} p-5`}>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 text-center w-10">
                <div class={`w-8 h-8 rounded-full ${level.dot} mx-auto mb-1 flex items-center justify-center`}>
                  <span class="font-display text-sm text-background font-bold">{level.n}</span>
                </div>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-2 mb-2">
                  <h3 class="font-display text-lg" style={`color: ${level.color}`}>{level.name}</h3>
                  <span class="font-mono text-[0.6rem] text-muted-foreground">{level.subtitle}</span>
                </div>
                <p class="text-xs text-muted-foreground mb-2"><strong class="text-foreground/70">Who:</strong> {level.who}</p>
                <p class="text-xs italic text-muted-foreground border-l-2 pl-3" style={`border-color: ${level.color}40`}>{level.feel}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full vocabulary table -->
  <section class="py-16 border-b border-border">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="mb-8 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Vocabulary map</span>
        <span class="h-px flex-1 bg-border"></span>
        <span class="font-mono text-[0.6rem] text-dim">Same concept · 5 languages</span>
      </div>

      <div class="space-y-10">
        {vocab.map((section) => (
          <div>
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-dim mb-3">{section.category}</p>
            <div class="rounded-xl border border-border overflow-hidden">
              <!-- Header -->
              <div class="grid bg-card/80 border-b border-border" style="grid-template-columns: 1.4fr repeat(5, 1fr)">
                <div class="px-4 py-2.5">
                  <span class="font-mono text-[0.55rem] uppercase tracking-[0.15em] text-dim">Concept</span>
                </div>
                {colNames.map((name, i) => (
                  <div class="px-3 py-2.5 text-center">
                    <span class="font-mono text-[0.55rem] font-medium" style={`color: ${colColors[i]}`}>{name}</span>
                  </div>
                ))}
              </div>
              <!-- Rows -->
              {section.rows.map((row, ri) => (
                <div
                  class={`grid border-b border-border/50 last:border-0 ${ri % 2 === 0 ? "" : "bg-card/30"}`}
                  style="grid-template-columns: 1.4fr repeat(5, 1fr)"
                >
                  <div class="px-4 py-2.5">
                    <span class="text-xs text-foreground/60">{row.concept}</span>
                  </div>
                  {[row.b1, row.f3, row.m5, row.n7, row.num10].map((val, i) => (
                    <div class="px-3 py-2.5 text-center">
                      <span class="font-mono text-[0.6rem]" style={`color: ${colColors[i]}cc`}>{val}</span>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why this matters -->
  <section class="py-16 border-b border-border">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="mb-6 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Why this changes everything</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          {
            title: "Narrative is a feature, not a requirement",
            desc: "The system works at dial 1. No lore needed. Organizations that want the narrative can unlock it — organizations that don't can ignore it completely.",
          },
          {
            title: "Solves the first-impression problem",
            desc: "A traditional C-suite sees a structured work OS with AI agents. A gaming studio sees a living narrative world. Same system. Different entry points.",
          },
          {
            title: "Gamification is independent",
            desc: "A company can have full gamification (ranks, achievements, tokens) at narrative level 1. The mechanics don't require the metaphors.",
          },
          {
            title: "Numinia is the reference, not the constraint",
            desc: "Numinia (10/10) is what full adoption looks like. It's the vision, not the requirement. Every organization starts wherever they are.",
          },
        ].map((item) => (
          <div class="rounded-xl border border-border bg-card p-5">
            <p class="font-semibold text-sm text-foreground mb-2">{item.title}</p>
            <p class="text-xs text-muted-foreground leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Status -->
  <section class="py-12">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="rounded-xl border border-yellow/20 bg-yellow/5 p-6">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-yellow mb-3">⚡ Work in progress — MIS-055</p>
        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
          This page documents a system design proposal that emerged from the Dark Council on 2026-04-06. The vocabulary table above is a first proposal — it will evolve.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Once validated, this becomes <strong class="text-foreground">DEC-006</strong> — a decision that modifies the NWOS architecture to include the two-dial system as a standard configuration parameter.
        </p>
        <div class="flex flex-wrap gap-3 mt-4">
          <a href="/misiones" class="font-mono text-[0.65rem] text-accent hover:text-accent/80 transition-colors">MIS-055 →</a>
          <a href="/decisiones" class="font-mono text-[0.65rem] text-dim hover:text-foreground transition-colors">Decision Registry →</a>
          <a href="/nwos" class="font-mono text-[0.65rem] text-dim hover:text-foreground transition-colors">NWOS overview →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
