---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import { planos } from "@/data/planos";

const semaforo: Record<string, { color: string; label: string; dot: string }> = {
  verde: { color: "bg-green/10 text-green border-green/20", label: "Operativo", dot: "bg-green" },
  amarillo: { color: "bg-yellow/10 text-yellow border-yellow/20", label: "En progreso", dot: "bg-yellow" },
  rojo: { color: "bg-red/10 text-red border-red/20", label: "Atención", dot: "bg-red" },
};

const areas = [...new Set(planos.map(p => p.area))];
const pendientes = ["plano-numinia", "plano-jugador", "plano-lore"];
---

<Layout
  title="Los Planos del Mundo — Numen Games"
  description="Arquitectura viva de Numen Games / Numinia. El Modelo Funcional hecho visible."
  canonicalPath="/planos"
  activeNav="planos"
>
  <PageHero
    label="CAO · Registro Akáshico"
    title="Los Planos del Mundo"
    description="Todo sistema que existe puede ser trazado. Todo lo que puede ser trazado, puede ser mejorado."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Stats -->
      <div class="grid gap-4 sm:grid-cols-4 mb-12">
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class="font-display text-3xl text-foreground">{planos.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Planos activos</p>
        </div>
        <div class="rounded-xl border border-green/20 bg-green/5 p-5 text-center">
          <p class="font-display text-3xl text-green">{planos.filter(p => p.semaforo === "verde").length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">🟢 Operativos</p>
        </div>
        <div class="rounded-xl border border-yellow/20 bg-yellow/5 p-5 text-center">
          <p class="font-display text-3xl text-yellow">{planos.filter(p => p.semaforo === "amarillo").length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">🟡 En progreso</p>
        </div>
        <div class="rounded-xl border border-red/20 bg-red/5 p-5 text-center">
          <p class="font-display text-3xl text-red">{planos.filter(p => p.semaforo === "rojo").length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">🔴 Atención</p>
        </div>
      </div>

      <!-- Grid de planos -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Planos activos</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-12">
        {planos.map((p) => (
          <a href={`/planos/${p.id}`} class="rounded-xl border border-border bg-card p-6 hover:bg-card-hover transition-colors block">
            <div class="flex items-start justify-between mb-4">
              <span class:list={["inline-flex items-center gap-1.5 rounded-full border px-2.5 py-0.5 font-mono text-[0.6rem] font-medium", semaforo[p.semaforo].color]}>
                <span class:list={["h-1.5 w-1.5 rounded-full", semaforo[p.semaforo].dot]}></span>
                {semaforo[p.semaforo].label}
              </span>
              <span class="font-mono text-[0.6rem] text-dim">{p.version}</span>
            </div>

            <h3 class="font-display text-xl text-foreground mb-2">{p.titulo}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">{p.descripcion}</p>

            <div class="border-t border-border pt-4">
              <p class="font-mono text-[0.6rem] text-dim italic line-clamp-2">"{p.lore}"</p>
            </div>

            <div class="flex items-center justify-between mt-3">
              <span class="font-mono text-[0.55rem] text-dim">{p.area}</span>
              <span class="font-mono text-[0.6rem] text-accent">Ver plano →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Planos pendientes -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Pendientes de trazar</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-3 sm:grid-cols-3 mb-12">
        {[
          { id: "plano-numinia", titulo: "Plano de Numinia", desc: "La ciudad como sistema vivo: zonas, facciones, flujo narrativo." },
          { id: "plano-jugador", titulo: "Plano del Jugador", desc: "El viaje del usuario: cómo entra, qué encuentra, cómo progresa." },
          { id: "plano-lore", titulo: "Plano del Lore", desc: "Arquitectura narrativa: deidades, historia, capas de verdad." },
        ].map((p) => (
          <div class="rounded-xl border border-border/50 bg-card/50 p-5 opacity-60">
            <p class="font-mono text-[0.6rem] text-dim mb-2">⏳ Pendiente</p>
            <h3 class="font-display text-lg text-foreground mb-1">{p.titulo}</h3>
            <p class="text-xs text-muted-foreground">{p.desc}</p>
          </div>
        ))}
      </div>

      <!-- Protocolo -->
      <div class="rounded-xl border border-border/50 bg-card/50 p-6">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">Protocolo de Cartografía CAO</p>
        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
          Cada plano responde a las 5W del periodismo aplicadas a la arquitectura. Tienen valor epistémico (qué aprendemos al leerlos) y pragmático (qué podemos hacer con ellos).
        </p>
        <a href="/planos/meta" class="font-mono text-[0.7rem] text-accent hover:text-accent/80 transition-colors">
          Ver el protocolo completo →
        </a>
      </div>

    </div>
  </section>
</Layout>
