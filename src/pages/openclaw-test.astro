---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
---

<Layout
  title="OpenClawTest — Pablo FM"
  description="Sandbox de demos en vivo. Aquí experimento con Centinela-01 en tiempo real."
  canonicalPath="/openclaw-test"
  activeNav="openclaw-test"
>
  <PageHero
    label="🧪 Demo en vivo"
    title="OpenClawTest"
    description="Este espacio es un sandbox. Lo que ves aquí lo edita Centinela-01 en tiempo real."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Info box -->
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6 mb-12">
        <p class="font-mono text-[0.75rem] uppercase tracking-[0.2em] text-accent mb-2">¿Qué es esto?</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Una demostración en vivo de <strong class="text-foreground">Centinela-01</strong>, el agente digital de Numen Games.
          Le doy una instrucción por Telegram y edita esta página en segundos — sin tocar código, sin abrir un editor.
        </p>
      </div>

      <!-- Demo content area — editado por Centinela-01 -->
      <div id="demo-content">

        <!-- RUSOWSKY -->
        <div class="mb-4 flex items-center gap-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">Artista</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>

        <h2 class="font-display text-5xl text-foreground mb-2">Rusowsky</h2>
        <p class="font-mono text-sm text-muted-foreground mb-8">Ruslán Mediavilla · Valladolid, 1999 · Madrid</p>

        <p class="text-muted-foreground leading-relaxed max-w-prose mb-12">
          Cantante, compositor y productor español criado en Fuenlabrada. Formación clásica desde los 4 años,
          influenciado por Tyler, the Creator. Su música mezcla bedroom pop, R&B, reggaetón alternativo
          y melancolía digital. Uno de los nombres más interesantes del indie español contemporáneo.
        </p>

        <!-- Hitos -->
        <div class="grid gap-4 sm:grid-cols-3 mb-12">
          <div class="rounded-lg border border-border bg-card p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Debut</p>
            <p class="font-display text-xl text-foreground">2019</p>
            <p class="text-xs text-muted-foreground mt-1">Primeros temas en plataformas digitales</p>
          </div>
          <div class="rounded-lg border border-border bg-card p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Álbum debut</p>
            <p class="font-display text-xl text-foreground">Daisy</p>
            <p class="text-xs text-muted-foreground mt-1">Mayo 2025 · 13 canciones</p>
          </div>
          <div class="rounded-lg border border-border bg-card p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Gira mundial</p>
            <p class="font-display text-xl text-foreground">Daisy Tour</p>
            <p class="text-xs text-muted-foreground mt-1">2025–2026</p>
          </div>
        </div>

        <!-- Colaboraciones -->
        <div class="mb-4 flex items-center gap-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Colaboraciones destacadas</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <div class="flex flex-wrap gap-2 mb-12">
          {["C. Tangana", "Aitana", "Dellafuente", "Najwa", "Ralphie Choo", "Jean Dawson", "Las Ketchup", "La Zowi", "Kevin Abstract"].map((name) => (
            <span class="rounded-full border border-border bg-background px-3 py-1 font-mono text-[0.65rem] text-muted-foreground">
              {name}
            </span>
          ))}
        </div>

        <!-- Géneros -->
        <div class="mb-4 flex items-center gap-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Géneros</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <div class="flex flex-wrap gap-2 mb-12">
          {["Bedroom pop", "R&B", "Reggaetón alternativo", "Trap", "Experimental", "Pop electrónico"].map((g) => (
            <span class="rounded-full border border-accent/30 bg-accent/5 px-3 py-1 font-mono text-[0.65rem] text-accent">
              {g}
            </span>
          ))}
        </div>

        <!-- CTA Spotify -->
        <a
          href="https://open.spotify.com/artist/3Pm2YSZ0zE6nXNPRin3P3L"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-11 items-center gap-2 rounded-lg bg-accent px-6 text-sm font-semibold text-background transition-colors hover:bg-accent/90"
        >
          Escuchar en Spotify
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

      </div>

    </div>
  </section>
</Layout>
