---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
---

<Layout
  title="OpenClawTest — Pablo FM"
  description="Sandbox de demos en vivo. Aquí experimento con Centinela-01 en tiempo real."
  canonicalPath="/openclaw-test"
  activeNav="openclaw-test"
>
  <PageHero
    label="🧪 Demo en vivo"
    title="OpenClawTest"
    description="Este espacio es un sandbox. Lo que ves aquí lo edita Nimrod en tiempo real."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Info box -->
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6 mb-12">
        <p class="font-mono text-[0.75rem] uppercase tracking-[0.2em] text-accent mb-2">El Velo — Primer Nivel</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Eres un <strong class="text-foreground">Nómada</strong> — el rango más joven de Numinia.
          Cruza el Velo y alcanza el portal antes de que los <strong class="text-foreground">Desgarraformas</strong> te fragmenten.
          <span class="font-mono text-xs text-accent ml-2">WASD · Muévete</span>
        </p>
      </div>

      <!-- Game container -->
      <div class="relative rounded-xl overflow-hidden border border-accent/20 mb-8" style="aspect-ratio: 16/9; max-height: 540px;">
        <canvas id="velo-canvas" style="width:100%;height:100%;display:block;"></canvas>

        <!-- UI overlay -->
        <div id="game-ui" class="absolute inset-0 pointer-events-none">
          <!-- HUD top -->
          <div class="absolute top-4 left-4 right-4 flex justify-between items-start">
            <div class="rounded-lg bg-black/60 backdrop-blur-sm border border-accent/20 px-3 py-2">
              <p class="font-mono text-[0.6rem] text-accent uppercase tracking-wider">Nómada</p>
              <div id="health-bar" class="w-24 h-1.5 bg-white/10 rounded-full mt-1 overflow-hidden">
                <div id="health-fill" class="h-full bg-accent rounded-full transition-all" style="width:100%"></div>
              </div>
            </div>
            <div class="rounded-lg bg-black/60 backdrop-blur-sm border border-border/40 px-3 py-2 text-right">
              <p class="font-mono text-[0.6rem] text-dim uppercase tracking-wider">Desgarraformas</p>
              <p id="enemy-count" class="font-mono text-sm text-foreground">4</p>
            </div>
          </div>

          <!-- Start screen -->
          <div id="start-screen" class="absolute inset-0 flex flex-col items-center justify-center bg-black/70 backdrop-blur-sm pointer-events-auto">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-accent mb-4">Numinia · El Velo</p>
            <h2 class="font-display text-4xl text-foreground mb-2">Nivel I</h2>
            <p class="text-muted-foreground text-sm mb-8">Al otro lado del Velo te espera el portal</p>
            <button id="start-btn" class="rounded-lg bg-accent px-8 py-3 font-mono text-sm font-semibold text-background hover:bg-accent/90 transition-colors">
              Cruzar el Velo
            </button>
            <p class="font-mono text-[0.6rem] text-dim mt-4">WASD para moverte</p>
          </div>

          <!-- Game over screen -->
          <div id="gameover-screen" class="absolute inset-0 flex flex-col items-center justify-center bg-black/80 backdrop-blur-sm pointer-events-auto hidden">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-red-400 mb-4">El Nómada ha sido fragmentado</p>
            <h2 class="font-display text-4xl text-foreground mb-8">Fragmentado</h2>
            <button id="retry-btn" class="rounded-lg border border-accent/40 px-8 py-3 font-mono text-sm text-accent hover:bg-accent/10 transition-colors">
              Renacer
            </button>
          </div>

          <!-- Win screen -->
          <div id="win-screen" class="absolute inset-0 flex flex-col items-center justify-center bg-black/80 backdrop-blur-sm pointer-events-auto hidden">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-accent mb-4">El Velo ha sido cruzado</p>
            <h2 class="font-display text-4xl text-foreground mb-2">Portal alcanzado</h2>
            <p class="text-muted-foreground text-sm mb-8">El Nómada avanza hacia el siguiente rango</p>
            <button id="play-again-btn" class="rounded-lg bg-accent px-8 py-3 font-mono text-sm font-semibold text-background hover:bg-accent/90 transition-colors">
              Volver a cruzar
            </button>
          </div>
        </div>
      </div>

      <p class="font-mono text-[0.6rem] text-dim text-center">
        Three.js · Web Audio API · Numinia Lore · pablofm.com/openclaw-test
      </p>

    </div>
  </section>
</Layout>

<script>
import * as THREE from 'https://esm.sh/three@0.163.0';

// ─── Audio Context ───────────────────────────────────────────────────
let audioCtx: AudioContext | null = null;
function getAudio() {
  if (!audioCtx) audioCtx = new AudioContext();
  return audioCtx;
}

function playStep() {
  try {
    const ctx = getAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.setValueAtTime(120, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 0.08);
    gain.gain.setValueAtTime(0.08, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.08);
    osc.start(); osc.stop(ctx.currentTime + 0.08);
  } catch(e) {}
}

function playHit() {
  try {
    const ctx = getAudio();
    const buf = ctx.createBuffer(1, ctx.sampleRate * 0.2, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * (1 - i / data.length);
    const src = ctx.createBufferSource();
    const gain = ctx.createGain();
    src.buffer = buf; src.connect(gain); gain.connect(ctx.destination);
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
    src.start();
  } catch(e) {}
}

function playWin() {
  try {
    const ctx = getAudio();
    [440, 550, 660, 880].forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, ctx.currentTime + i * 0.12);
      gain.gain.setValueAtTime(0, ctx.currentTime + i * 0.12);
      gain.gain.linearRampToValueAtTime(0.2, ctx.currentTime + i * 0.12 + 0.05);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.12 + 0.4);
      osc.start(ctx.currentTime + i * 0.12);
      osc.stop(ctx.currentTime + i * 0.12 + 0.4);
    });
  } catch(e) {}
}

function startAmbient() {
  try {
    const ctx = getAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.type = 'sine';
    osc.frequency.setValueAtTime(55, ctx.currentTime);
    gain.gain.setValueAtTime(0.03, ctx.currentTime);
    osc.start();
    return () => { gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5); osc.stop(ctx.currentTime + 0.5); };
  } catch(e) { return () => {}; }
}

// ─── Game ─────────────────────────────────────────────────────────────
const canvas = document.getElementById('velo-canvas') as HTMLCanvasElement;
const startScreen = document.getElementById('start-screen')!;
const gameoverScreen = document.getElementById('gameover-screen')!;
const winScreen = document.getElementById('win-screen')!;
const healthFill = document.getElementById('health-fill') as HTMLElement;
const enemyCountEl = document.getElementById('enemy-count')!;

const TEAL = 0x00d9c4;
const MAGENTA = 0xff2d55;
const WHITE = 0xffffff;
const GRID_SIZE = 20;
const PLAYER_SPEED = 0.07;
const ENEMY_SPEED = 0.025;
const ENEMY_COUNT = 4;

let renderer: THREE.WebGLRenderer;
let scene: THREE.Scene;
let camera: THREE.PerspectiveCamera;
let player: THREE.Mesh;
let portal: THREE.Mesh;
let enemies: THREE.Mesh[] = [];
let particles: THREE.Points;
let clock: THREE.Clock;
let keys: Record<string, boolean> = {};
let health = 100;
let gameState: 'idle' | 'playing' | 'dead' | 'won' = 'idle';
let stepTimer = 0;
let hitCooldown = 0;
let stopAmbient: () => void = () => {};
let animId = 0;

function initRenderer() {
  renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.setClearColor(0x000000);

  const rect = canvas.parentElement!.getBoundingClientRect();
  renderer.setSize(rect.width, rect.height);
}

function initScene() {
  scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x000000, 0.04);

  // Camera — isometric-ish
  camera = new THREE.PerspectiveCamera(50, canvas.width / canvas.height, 0.1, 100);
  camera.position.set(0, 12, 10);
  camera.lookAt(0, 0, 0);

  // Lights
  const ambient = new THREE.AmbientLight(0x111122, 1);
  scene.add(ambient);

  const dirLight = new THREE.DirectionalLight(0x00d9c4, 1.5);
  dirLight.position.set(5, 10, 5);
  dirLight.castShadow = true;
  dirLight.shadow.mapSize.set(1024, 1024);
  scene.add(dirLight);

  const pointLight = new THREE.PointLight(TEAL, 2, 15);
  pointLight.position.set(0, 3, -8); // near portal
  scene.add(pointLight);

  // Ground — grid
  const gridHelper = new THREE.GridHelper(GRID_SIZE, 20, TEAL, 0x112233);
  scene.add(gridHelper);

  const groundGeo = new THREE.PlaneGeometry(GRID_SIZE, GRID_SIZE);
  const groundMat = new THREE.MeshStandardMaterial({ color: 0x000814, roughness: 1 });
  const ground = new THREE.Mesh(groundGeo, groundMat);
  ground.rotation.x = -Math.PI / 2;
  ground.receiveShadow = true;
  scene.add(ground);

  // Obstacles — lowpoly rocks
  const obsMat = new THREE.MeshStandardMaterial({ color: 0x112233, roughness: 0.9, metalness: 0.1 });
  [[-4, 2], [3, -3], [-2, -5], [5, 1], [-6, -2], [4, -6]].forEach(([x, z]) => {
    const geo = new THREE.DodecahedronGeometry(0.6 + Math.random() * 0.3, 0);
    const obs = new THREE.Mesh(geo, obsMat);
    obs.position.set(x, 0.4, z);
    obs.rotation.set(Math.random(), Math.random(), Math.random());
    obs.castShadow = true;
    scene.add(obs);
  });

  // Player — Nómada (capsule-like: cylinder + sphere)
  const playerGroup = new THREE.Group();
  const bodyGeo = new THREE.CylinderGeometry(0.25, 0.2, 0.8, 6);
  const headGeo = new THREE.SphereGeometry(0.22, 6, 6);
  const playerMat = new THREE.MeshStandardMaterial({ color: TEAL, emissive: TEAL, emissiveIntensity: 0.3, roughness: 0.5 });
  const body = new THREE.Mesh(bodyGeo, playerMat);
  const head = new THREE.Mesh(headGeo, playerMat);
  head.position.y = 0.6;
  playerGroup.add(body, head);
  player = new THREE.Mesh(new THREE.SphereGeometry(0.4), new THREE.MeshBasicMaterial({ visible: false }));
  player.add(playerGroup);
  player.position.set(0, 0.55, 7);
  player.castShadow = true;
  scene.add(player);

  // Player glow
  const glowLight = new THREE.PointLight(TEAL, 1.5, 3);
  player.add(glowLight);

  // Portal — torus
  const portalGeo = new THREE.TorusGeometry(0.9, 0.15, 8, 24);
  const portalMat = new THREE.MeshStandardMaterial({ color: TEAL, emissive: TEAL, emissiveIntensity: 1.5, transparent: true, opacity: 0.9 });
  portal = new THREE.Mesh(portalGeo, portalMat);
  portal.position.set(0, 1, -8);
  portal.rotation.x = Math.PI / 12;
  scene.add(portal);

  const portalGlow = new THREE.PointLight(TEAL, 3, 6);
  portalGlow.position.copy(portal.position);
  scene.add(portalGlow);

  // Inner portal disc
  const discGeo = new THREE.CircleGeometry(0.85, 24);
  const discMat = new THREE.MeshBasicMaterial({ color: 0x002233, side: THREE.DoubleSide, transparent: true, opacity: 0.7 });
  const disc = new THREE.Mesh(discGeo, discMat);
  disc.position.copy(portal.position);
  disc.rotation.x = Math.PI / 12;
  scene.add(disc);

  // Enemies — Desgarraformas
  enemies = [];
  const ePositions = [[-5, 3], [5, 3], [-3, -2], [3, -4]];
  for (let i = 0; i < ENEMY_COUNT; i++) {
    const geo = new THREE.OctahedronGeometry(0.45, 0);
    const mat = new THREE.MeshStandardMaterial({
      color: MAGENTA, emissive: MAGENTA, emissiveIntensity: 0.6,
      roughness: 0.3, wireframe: Math.random() > 0.5
    });
    const e = new THREE.Mesh(geo, mat);
    e.position.set(ePositions[i][0], 0.7, ePositions[i][1]);
    e.castShadow = true;
    const eLight = new THREE.PointLight(MAGENTA, 1, 2.5);
    e.add(eLight);
    scene.add(e);
    enemies.push(e);
  }

  // Particles — Velo dust
  const pCount = 300;
  const pGeo = new THREE.BufferGeometry();
  const pPos = new Float32Array(pCount * 3);
  for (let i = 0; i < pCount; i++) {
    pPos[i * 3] = (Math.random() - 0.5) * GRID_SIZE;
    pPos[i * 3 + 1] = Math.random() * 4;
    pPos[i * 3 + 2] = (Math.random() - 0.5) * GRID_SIZE;
  }
  pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
  const pMat = new THREE.PointsMaterial({ color: TEAL, size: 0.05, transparent: true, opacity: 0.4 });
  particles = new THREE.Points(pGeo, pMat);
  scene.add(particles);

  clock = new THREE.Clock();
}

function resetGame() {
  health = 100;
  hitCooldown = 0;
  healthFill.style.width = '100%';
  healthFill.style.backgroundColor = '';
  player.position.set(0, 0.55, 7);
  enemies.forEach((e, i) => {
    const pos = [[-5, 3], [5, 3], [-3, -2], [3, -4]];
    e.position.set(pos[i][0], 0.7, pos[i][1]);
    e.visible = true;
  });
  enemyCountEl.textContent = ENEMY_COUNT.toString();
}

function startGame() {
  resetGame();
  gameState = 'playing';
  startScreen.classList.add('hidden');
  gameoverScreen.classList.add('hidden');
  winScreen.classList.add('hidden');
  stopAmbient = startAmbient();
}

function endGame(won: boolean) {
  gameState = won ? 'won' : 'dead';
  stopAmbient();
  if (won) {
    playWin();
    winScreen.classList.remove('hidden');
  } else {
    playHit();
    gameoverScreen.classList.remove('hidden');
  }
}

function gameLoop() {
  animId = requestAnimationFrame(gameLoop);
  if (gameState !== 'playing') {
    renderer.render(scene, camera);
    return;
  }

  const delta = clock.getDelta();
  const t = clock.getElapsedTime();

  // Player movement
  const moveX = (keys['d'] || keys['arrowright'] ? 1 : 0) - (keys['a'] || keys['arrowleft'] ? 1 : 0);
  const moveZ = (keys['s'] || keys['arrowdown'] ? 1 : 0) - (keys['w'] || keys['arrowup'] ? 1 : 0);
  const len = Math.sqrt(moveX * moveX + moveZ * moveZ);

  if (len > 0) {
    const nx = moveX / len * PLAYER_SPEED;
    const nz = moveZ / len * PLAYER_SPEED;
    const nx2 = player.position.x + nx;
    const nz2 = player.position.z + nz;
    if (Math.abs(nx2) < GRID_SIZE / 2 - 0.5) player.position.x = nx2;
    if (Math.abs(nz2) < GRID_SIZE / 2 - 0.5) player.position.z = nz2;

    // Face direction
    player.rotation.y = Math.atan2(moveX, moveZ);

    stepTimer += delta;
    if (stepTimer > 0.25) { playStep(); stepTimer = 0; }
  }

  // Camera follow
  camera.position.x += (player.position.x - camera.position.x) * 0.05;
  camera.position.z += (player.position.z + 10 - camera.position.z) * 0.05;
  camera.lookAt(player.position.x, 0, player.position.z);

  // Enemies
  let visibleEnemies = 0;
  enemies.forEach((e) => {
    if (!e.visible) return;
    visibleEnemies++;

    // Rotate (desgarraforma effect)
    e.rotation.x += delta * 1.5;
    e.rotation.z += delta * 2;

    // Pulse scale
    const pulse = 1 + Math.sin(t * 3 + e.position.x) * 0.1;
    e.scale.setScalar(pulse);

    // Chase player
    const dx = player.position.x - e.position.x;
    const dz = player.position.z - e.position.z;
    const dist = Math.sqrt(dx * dx + dz * dz);
    if (dist > 0.5) {
      e.position.x += dx / dist * ENEMY_SPEED;
      e.position.z += dz / dist * ENEMY_SPEED;
    }

    // Collision
    if (hitCooldown <= 0 && dist < 0.8) {
      health -= 20;
      hitCooldown = 1.5;
      playHit();
      healthFill.style.width = Math.max(0, health) + '%';
      if (health <= 20) healthFill.style.backgroundColor = '#ff2d55';
      if (health <= 0) { endGame(false); return; }
    }
  });

  enemyCountEl.textContent = visibleEnemies.toString();
  if (hitCooldown > 0) hitCooldown -= delta;

  // Portal collision
  const pdx = player.position.x - portal.position.x;
  const pdz = player.position.z - portal.position.z;
  if (Math.sqrt(pdx * pdx + pdz * pdz) < 1.2) {
    endGame(true);
  }

  // Animations
  portal.rotation.z += delta * 1.2;
  portal.rotation.y += delta * 0.5;
  portal.position.y = 1 + Math.sin(t * 2) * 0.1;

  player.children[0].position.y = Math.sin(t * 8) * 0.03;

  // Particles drift
  const pPos = (particles.geometry.attributes.position as THREE.BufferAttribute).array as Float32Array;
  for (let i = 0; i < pPos.length; i += 3) {
    pPos[i + 1] += delta * 0.1;
    if (pPos[i + 1] > 4) pPos[i + 1] = 0;
  }
  (particles.geometry.attributes.position as THREE.BufferAttribute).needsUpdate = true;

  renderer.render(scene, camera);
}

// ─── Init ──────────────────────────────────────────────────────────────
initRenderer();
initScene();
gameLoop();

// Events
window.addEventListener('keydown', (e) => { keys[e.key.toLowerCase()] = true; });
window.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

document.getElementById('start-btn')!.addEventListener('click', startGame);
document.getElementById('retry-btn')!.addEventListener('click', startGame);
document.getElementById('play-again-btn')!.addEventListener('click', startGame);

window.addEventListener('resize', () => {
  const rect = canvas.parentElement!.getBoundingClientRect();
  renderer.setSize(rect.width, rect.height);
  camera.aspect = rect.width / rect.height;
  camera.updateProjectionMatrix();
});

// Mobile — touch controls (basic)
const touchStart: Record<string, boolean> = {};
document.getElementById('velo-canvas')?.addEventListener('touchstart', (e) => e.preventDefault(), { passive: false });
</script>
