---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
---

<Layout
  title="OpenClawTest — Pablo FM"
  description="Sandbox de demos en vivo. Aquí experimento con Centinela-01 en tiempo real."
  canonicalPath="/openclaw-test"
  activeNav="openclaw-test"
>
  <PageHero
    label="🧪 Demo en vivo"
    title="OpenClawTest"
    description="Este espacio es un sandbox. Lo que ves aquí lo edita Centinela-01 en tiempo real."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Info box -->
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6 mb-12">
        <p class="font-mono text-[0.75rem] uppercase tracking-[0.2em] text-accent mb-2">¿Qué es esto?</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Una demostración en vivo de <strong class="text-foreground">Centinela-01</strong>, el agente digital de Numen Games.
          Le doy una instrucción por Telegram y edita esta página en segundos — sin tocar código, sin abrir un editor.
        </p>
      </div>

      <!-- Demo content area — editado por Centinela-01 -->
      <div id="demo-content">

        <!-- ORACLES -->
        <div class="mb-4 flex items-center gap-3">
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">Numen Games</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>

        <h2 class="font-display text-4xl text-foreground mb-2">Los Oráculos</h2>
        <p class="text-muted-foreground text-sm mb-10 max-w-prose">
          Los fundadores de Numen Games. Emprendedores unidos por la amistad, el juego y la visión de transformar cómo trabajan las organizaciones.
        </p>

        <!-- Foto de grupo -->
        <div class="rounded-xl overflow-hidden border border-border mb-12">
          <img
            src="/oracles.jpg"
            alt="Pablo FM y Daniel Garrido — Oráculos de Numen Games"
            class="w-full object-cover max-h-[480px]"
          />
        </div>

        <!-- Cards de Oráculos -->
        <div class="grid gap-6 sm:grid-cols-2 mb-12">

          <!-- Pablo FM -->
          <div class="rounded-xl border border-border bg-card p-8">
            <div class="mb-4">
              <span class="inline-block rounded-full bg-accent/10 px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.2em] text-accent">CEO & Oracle</span>
            </div>
            <h3 class="font-display text-2xl text-foreground mb-1">Pablo <em class="text-accent">FM</em></h3>
            <p class="font-mono text-xs text-dim mb-4">Pablo Fernández-Maquieira</p>
            <p class="text-sm leading-relaxed text-muted-foreground mb-6">
              Emprendedor, cofundador de Videona, seed investor en BackFund y mentor en Tetuan Valley.
              Oracle y visión estratégica de Numen Games.
            </p>
            <div class="flex gap-3">
              <a href="https://www.linkedin.com/in/pablofm" target="_blank" rel="noopener noreferrer"
                class="font-mono text-xs text-muted-foreground hover:text-accent transition-colors">LinkedIn ↗</a>
              <a href="https://x.com/Pablo_FMM" target="_blank" rel="noopener noreferrer"
                class="font-mono text-xs text-muted-foreground hover:text-accent transition-colors">X ↗</a>
              <a href="https://pablofm.com" target="_blank" rel="noopener noreferrer"
                class="font-mono text-xs text-muted-foreground hover:text-accent transition-colors">Web ↗</a>
            </div>
          </div>

          <!-- Daniel Garrido -->
          <div class="rounded-xl border border-border bg-card p-8">
            <div class="mb-4">
              <span class="inline-block rounded-full bg-accent/10 px-3 py-1 font-mono text-[0.6rem] uppercase tracking-[0.2em] text-accent">Analytics Wizard & Oracle</span>
            </div>
            <h3 class="font-display text-2xl text-foreground mb-1">Daniel <em class="text-accent">Garrido</em></h3>
            <p class="font-mono text-xs text-dim mb-4">Daniel Pérez Garrido</p>
            <p class="text-sm leading-relaxed text-muted-foreground mb-6">
              Especialista en data analytics y visualización con 16+ años de experiencia.
              Explora Web3, blockchain e IA generativa como Oracle de Numen Games.
            </p>
            <div class="flex gap-3">
              <a href="https://es.linkedin.com/in/daniel-garrido-p%C3%A9rez" target="_blank" rel="noopener noreferrer"
                class="font-mono text-xs text-muted-foreground hover:text-accent transition-colors">LinkedIn ↗</a>
            </div>
          </div>

        </div>

        <!-- CTA -->
        <a
          href="https://numen.games"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-11 items-center gap-2 rounded-lg bg-accent px-6 text-sm font-semibold text-background transition-colors hover:bg-accent/90"
        >
          Conoce Numen Games
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>



      </div>

    </div>
  </section>
</Layout>
