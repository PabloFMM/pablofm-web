---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";

// Métricas de la CAO — actualizadas por los agentes
const metrics = {
  updated: "2026-04-05",
  period: "2026-04-02 / 2026-04-05",
  agentes: [
    {
      id: "centinela-01",
      nombre: "Centinela-01",
      rol: "Operations & Coordination",
      gremio: "Centinelas",
      modelo: "claude-sonnet-4.6",
      estado: "activo",
      misiones: 47,
      prs: 10,
      docs: 12,
      coste: 50,
      color: "accent",
    },
    {
      id: "alquimista-01",
      nombre: "Alquimista-01",
      rol: "CTO Digital",
      gremio: "Alquimistas",
      modelo: "claude-sonnet-4.6",
      estado: "diseñado",
      misiones: 0,
      prs: 0,
      docs: 0,
      coste: 0,
      color: "yellow",
    },
    {
      id: "exegeta-01",
      nombre: "Exegeta-01",
      rol: "Content & Lore",
      gremio: "Exegetas",
      modelo: "claude-haiku-3.5",
      estado: "diseñado",
      misiones: 0,
      prs: 0,
      docs: 0,
      coste: 0,
      color: "blue",
    },
    {
      id: "procurador-01",
      nombre: "Procurador-01",
      rol: "Sales & BD",
      gremio: "Procuradores",
      modelo: "claude-haiku-3.5",
      estado: "diseñado",
      misiones: 0,
      prs: 0,
      docs: 0,
      coste: 0,
      color: "purple",
    },
    {
      id: "procyon",
      nombre: "Procyon",
      rol: "CAO Coordinator",
      gremio: "Coordinador",
      modelo: "claude-sonnet-4.6",
      estado: "previsto-2028",
      misiones: 0,
      prs: 0,
      docs: 0,
      coste: 0,
      color: "green",
    },
  ],
  totales: {
    misiones: 47,
    coste: 50,
    activos: 1,
    total: 5,
  },
};

const estadoStyles: Record<string, string> = {
  "activo": "bg-green/10 text-green",
  "diseñado": "bg-accent/10 text-accent",
  "previsto-2028": "bg-muted text-muted-foreground",
};

const estadoLabel: Record<string, string> = {
  "activo": "Activo",
  "diseñado": "Diseñado",
  "previsto-2028": "Previsto 2028",
};
---

<Layout
  title="CAO Dashboard — Numen Games"
  description="Panel de métricas de la Organización Autónoma Centralizada de Numen Games. Agentes digitales, misiones, costes y ROI."
  canonicalPath="/cao"
  activeNav="cao"
>
  <PageHero
    label="Numen Games · CAO"
    title="Dashboard de Agentes"
    description="Métricas en tiempo real de los agentes digitales de la Organización Autónoma Centralizada."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Meta info -->
      <div class="mb-10 flex flex-wrap gap-6 font-mono text-[0.7rem] text-dim">
        <span>Período <span class="text-muted-foreground">{metrics.period}</span></span>
        <span>Actualizado <span class="text-muted-foreground">{metrics.updated}</span></span>
      </div>

      <!-- KPIs globales -->
      <div class="grid gap-4 sm:grid-cols-4 mb-12">
        <div class="rounded-xl border border-border bg-card p-6">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Misiones</p>
          <p class="font-display text-4xl text-foreground">{metrics.totales.misiones}</p>
          <p class="text-xs text-muted-foreground mt-1">completadas</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-6">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Coste total</p>
          <p class="font-display text-4xl text-foreground">${metrics.totales.coste}</p>
          <p class="text-xs text-muted-foreground mt-1">USD en 3 días</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-6">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mb-2">Agentes activos</p>
          <p class="font-display text-4xl text-foreground">{metrics.totales.activos}<span class="text-muted-foreground text-2xl">/{metrics.totales.total}</span></p>
          <p class="text-xs text-muted-foreground mt-1">de {metrics.totales.total} diseñados</p>
        </div>
        <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">ROI estimado</p>
          <p class="font-display text-2xl text-foreground">+40x</p>
          <p class="text-xs text-muted-foreground mt-1">infra valorada >$2K</p>
        </div>
      </div>

      <!-- Agentes -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Agentes</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {metrics.agentes.map((agente) => (
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="flex items-start justify-between mb-4">
              <span class:list={["inline-flex rounded-full px-2 py-0.5 font-mono text-[0.6rem] font-medium", estadoStyles[agente.estado] || "bg-muted text-muted-foreground"]}>
                {estadoLabel[agente.estado] || agente.estado}
              </span>
              <span class="font-mono text-[0.6rem] text-dim">{agente.modelo}</span>
            </div>

            <h3 class="font-display text-xl text-foreground mb-1">{agente.nombre}</h3>
            <p class="font-mono text-xs text-dim mb-1">{agente.rol}</p>
            <p class="font-mono text-xs text-muted-foreground mb-5">{agente.gremio}</p>

            <div class="grid grid-cols-3 gap-3 border-t border-border pt-4">
              <div>
                <p class="font-mono text-[0.6rem] text-dim mb-1">Misiones</p>
                <p class="font-display text-lg text-foreground">{agente.misiones}</p>
              </div>
              <div>
                <p class="font-mono text-[0.6rem] text-dim mb-1">PRs</p>
                <p class="font-display text-lg text-foreground">{agente.prs}</p>
              </div>
              <div>
                <p class="font-mono text-[0.6rem] text-dim mb-1">Coste</p>
                <p class="font-display text-lg text-foreground">${agente.coste}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Nota -->
      <div class="mt-12 rounded-xl border border-border/50 bg-card/50 p-6">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">Sobre este dashboard</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Métricas de la CAO (Organización Autónoma Centralizada) de Numen Games. Los agentes digitales operan 24/7 ejecutando misiones mientras los Oráculos descansan. Actualización automática en cada ciclo de reporting.
        </p>
      </div>

    </div>
  </section>
</Layout>
