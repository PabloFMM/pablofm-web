---
import Layout from "@/layouts/Layout.astro";

// Auto-detect images in /public/sa/ - we list them statically here.
// To add more photos, just drop files in /public/sa/ and add them to this array.
const photos = [
  { src: "/sa/foto-01.jpg", alt: "Camino a Madrid — S.A. 09.04.2026" },
  // Add more photos here as: { src: "/sa/foto-02.jpg", alt: "..." },
];

const ewokAscii = `
  ,_,
 (o,o)
 {»»»}
  " "
`;

const ewokFooter = `
  ,_,
 (·,·)
 {||||}
  " "
`;
---

<Layout
  title="S.A. — SOZIEDAD ALKOHOLIKA · MADRID 09.04.2026"
  description="Soziedad Alkoholika en Madrid, 9 de Abril 2026. Vitoria, 1988. Thrash. Hardcore. 35 años sin parar."
  activeNav="sa"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Creepster&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ============================================================
         S.A. PAGE — 90s Underground Fanzine Aesthetic
         ============================================================ */

      .sa-page {
        background: #000000;
        min-height: 100vh;
        position: relative;
        color: #E8E0D0;
        font-family: 'Special Elite', serif;
        overflow-x: hidden;
      }

      /* Grain/noise overlay */
      .sa-page::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 100;
        opacity: 0.08;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 256px 256px;
      }

      /* Additional scanline effect */
      .sa-page::after {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 99;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0,0,0,0.03) 2px,
          rgba(0,0,0,0.03) 4px
        );
      }

      /* ---- HERO ---- */
      .sa-hero {
        text-align: center;
        padding: 80px 20px 60px;
        border-bottom: 3px solid #CC0000;
        position: relative;
      }

      .sa-hero::before {
        content: attr(data-ewok);
        position: absolute;
        top: 30px;
        left: 40px;
        font-size: 10px;
        color: #CC0000;
        opacity: 0.7;
        white-space: pre;
        font-family: monospace;
        line-height: 1.2;
      }

      .sa-hero::after {
        content: attr(data-ewok);
        position: absolute;
        top: 30px;
        right: 40px;
        font-size: 10px;
        color: #CC0000;
        opacity: 0.5;
        white-space: pre;
        font-family: monospace;
        line-height: 1.2;
        transform: scaleX(-1);
      }

      .sa-title {
        font-family: 'Creepster', cursive;
        font-size: clamp(6rem, 20vw, 14rem);
        color: #CC0000;
        line-height: 0.85;
        letter-spacing: -0.02em;
        text-shadow:
          4px 4px 0px #800000,
          8px 8px 0px #400000,
          2px 0px 20px rgba(204,0,0,0.5);
        margin: 0;
        /* Distressed effect via clip */
        -webkit-text-stroke: 1px #990000;
        filter: url(#rough);
      }

      .sa-subtitle {
        font-family: 'Special Elite', serif;
        font-size: clamp(0.9rem, 3vw, 1.4rem);
        color: #E8E0D0;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin: 12px 0 0;
        opacity: 0.9;
      }

      .sa-date {
        font-family: 'Special Elite', serif;
        font-size: clamp(1rem, 3vw, 1.6rem);
        color: #CC0000;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        margin: 16px 0 0;
        border: 2px solid #CC0000;
        display: inline-block;
        padding: 6px 24px;
        text-shadow: 1px 1px 0px #800000;
      }

      /* Sticker-style ewok in hero */
      .sa-hero-ewok {
        display: block;
        font-family: monospace;
        font-size: 11px;
        color: #CC0000;
        white-space: pre;
        line-height: 1.3;
        opacity: 0.8;
        margin: 24px auto 0;
        width: fit-content;
      }

      /* ---- GALLERY ---- */
      .sa-gallery-section {
        padding: 60px 20px;
        border-bottom: 3px solid #333;
        max-width: 1200px;
        margin: 0 auto;
      }

      .sa-section-label {
        font-family: 'Special Elite', serif;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #CC0000;
        border-left: 3px solid #CC0000;
        padding-left: 12px;
        margin-bottom: 32px;
      }

      .sa-gallery-grid {
        columns: 1;
        gap: 12px;
      }

      @media (min-width: 640px) {
        .sa-gallery-grid {
          columns: 2;
        }
      }

      @media (min-width: 1024px) {
        .sa-gallery-grid {
          columns: 3;
        }
      }

      .sa-gallery-item {
        break-inside: avoid;
        margin-bottom: 12px;
        position: relative;
        border: 2px solid #333;
        overflow: hidden;
        /* Photocopied look */
        filter: contrast(1.1) saturate(0.7);
        transition: filter 0.2s;
      }

      .sa-gallery-item:hover {
        filter: contrast(1.2) saturate(0.5) brightness(0.9);
        border-color: #CC0000;
      }

      .sa-gallery-item img {
        width: 100%;
        height: auto;
        display: block;
      }

      /* Tape effect on photos */
      .sa-gallery-item::before {
        content: '';
        position: absolute;
        top: -6px;
        left: 30%;
        width: 40%;
        height: 20px;
        background: rgba(232, 224, 208, 0.3);
        z-index: 1;
        transform: rotate(-1deg);
      }

      /* ---- BAND INFO ---- */
      .sa-band-section {
        padding: 60px 20px;
        border-bottom: 3px solid #333;
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: flex-start;
        gap: 40px;
        flex-wrap: wrap;
      }

      .sa-torn-paper {
        background: #E8E0D0;
        color: #1a1a1a;
        padding: 32px 40px;
        position: relative;
        flex: 1;
        min-width: 280px;
        max-width: 600px;
        /* Torn paper top edge */
        clip-path: polygon(
          0% 8px, 2% 0%, 5% 6px, 8% 1px, 11% 7px, 14% 2px, 17% 8px, 20% 1px,
          23% 6px, 26% 0%, 29% 7px, 32% 2px, 35% 8px, 38% 1px, 41% 6px, 44% 0%,
          47% 7px, 50% 2px, 53% 8px, 56% 1px, 59% 6px, 62% 0%, 65% 7px, 68% 2px,
          71% 8px, 74% 1px, 77% 6px, 80% 0%, 83% 7px, 86% 2px, 89% 8px, 92% 1px,
          95% 6px, 98% 0%, 100% 8px,
          100% 92%, 98% 100%, 95% 94%, 92% 100%, 89% 93%, 86% 100%, 83% 94%, 80% 100%,
          77% 93%, 74% 100%, 71% 94%, 68% 100%, 65% 93%, 62% 100%, 59% 94%, 56% 100%,
          53% 93%, 50% 100%, 47% 94%, 44% 100%, 41% 93%, 38% 100%, 35% 94%, 32% 100%,
          29% 93%, 26% 100%, 23% 94%, 20% 100%, 17% 93%, 14% 100%, 11% 94%, 8% 100%,
          5% 93%, 2% 100%, 0% 94%
        );
        box-shadow: 4px 4px 0px #CC0000, 6px 6px 0px #800000;
        transform: rotate(-0.5deg);
      }

      .sa-torn-paper p {
        font-family: 'Special Elite', serif;
        font-size: 1.1rem;
        line-height: 1.8;
        margin: 0;
        color: #1a1a1a;
      }

      .sa-torn-paper strong {
        color: #CC0000;
        font-size: 1.3rem;
        display: block;
        margin-bottom: 8px;
        font-family: 'Creepster', cursive;
        letter-spacing: 0.05em;
      }

      .sa-band-ewok {
        font-family: monospace;
        font-size: 13px;
        white-space: pre;
        color: #CC0000;
        line-height: 1.3;
        opacity: 0.8;
        transform: rotate(2deg);
        align-self: center;
        padding: 20px;
        border: 2px dashed #CC0000;
      }

      .sa-band-ewok-caption {
        display: block;
        text-align: center;
        font-size: 9px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #CC0000;
        opacity: 0.7;
        margin-top: 6px;
        font-family: 'Special Elite', serif;
      }

      /* ---- FOOTER ---- */
      .sa-footer {
        text-align: center;
        padding: 40px 20px;
        border-top: 3px solid #CC0000;
        background: #000;
        position: relative;
      }

      .sa-footer-title {
        font-family: 'Creepster', cursive;
        font-size: 3rem;
        color: #CC0000;
        text-shadow: 2px 2px 0px #800000;
        margin: 0 0 12px;
        letter-spacing: 0.1em;
      }

      .sa-footer-ewok {
        display: block;
        font-family: monospace;
        font-size: 12px;
        white-space: pre;
        color: #555;
        line-height: 1.3;
        margin: 0 auto;
        width: fit-content;
        margin-top: 16px;
      }

      /* SVG filter for rough/distressed text */
      .sa-svg-filters {
        position: absolute;
        width: 0;
        height: 0;
        overflow: hidden;
      }

      /* Decorative borders */
      .sa-border-decoration {
        text-align: center;
        color: #CC0000;
        font-size: 0.9rem;
        letter-spacing: 0.5em;
        margin: 0;
        padding: 12px 0;
        background: #0a0a0a;
        border-top: 1px solid #1a1a1a;
        border-bottom: 1px solid #1a1a1a;
        overflow: hidden;
        white-space: nowrap;
      }
    </style>
  </Fragment>

  <!-- Hidden SVG filters for distressed text effect -->
  <svg class="sa-svg-filters" aria-hidden="true">
    <defs>
      <filter id="rough" x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <div class="sa-page">

    <!-- Decorative ticker -->
    <div class="sa-border-decoration">
      ◆ SOZIEDAD ALKOHOLIKA ◆ VITORIA 1988 ◆ THRASH ◆ HARDCORE ◆ MADRID ◆ 09.04.2026 ◆ SOZIEDAD ALKOHOLIKA ◆ VITORIA 1988 ◆ THRASH ◆ HARDCORE ◆
    </div>

    <!-- HERO -->
    <section
      class="sa-hero"
      data-ewok={"  ,_,\n (o,o)\n {»»»}\n  \" \""}
    >
      <h1 class="sa-title">S.A.</h1>
      <p class="sa-subtitle">Soziedad Alkoholika</p>
      <p class="sa-date">Madrid · 09.04.2026</p>

      <!-- Ewok punk fan in hero -->
      <span class="sa-hero-ewok">{`
      ,_,       \\m/
     (ò,ó)   PUNK
     {||||}  IS NOT
      " "    DEAD`}</span>
    </section>

    <!-- GALLERY -->
    <section class="sa-gallery-section">
      <p class="sa-section-label">Fotos del concierto</p>

      {photos.length > 0 ? (
        <div class="sa-gallery-grid">
          {photos.map((photo) => (
            <div class="sa-gallery-item">
              <img
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      ) : (
        <p style="color: #555; font-family: 'Special Elite', serif; font-size: 0.9rem; letter-spacing: 0.1em;">
          // fotos próximamente —
        </p>
      )}
    </section>

    <!-- BAND INFO -->
    <section class="sa-band-section">
      <div class="sa-torn-paper">
        <p>
          <strong>Soziedad Alkoholika</strong>
          Vitoria, 1988. Thrash. Hardcore.<br />
          35 años sin parar.<br /><br />
          Crossover. Rabia. El sonido que te rompe las costillas y te hace creer que el mundo puede ser distinto.
        </p>
      </div>

      <!-- Punk Ewok mascot -->
      <div class="sa-band-ewok">
{`  ,_,
 (X,X)  <- punk ewok
 /|||\\ 
  / \\
mohawk
&amp; all`}
        <span class="sa-band-ewok-caption">ewok de Endor<br/>fan de S.A. desde 1988</span>
      </div>
    </section>

    <!-- Decorative ticker -->
    <div class="sa-border-decoration">
      ◆ NO FUTURE ◆ SOZIEDAD ALKOHOLIKA ◆ VITORIA ◆ EUSKAL HERRIA ◆ THRASH METAL ◆ HARDCORE PUNK ◆ NO FUTURE ◆ SOZIEDAD ALKOHOLIKA ◆
    </div>

    <!-- FOOTER -->
    <footer class="sa-footer">
      <p class="sa-footer-title">S.A.</p>
      <span class="sa-footer-ewok">{`  ,_,\n (·,·)\n {||||}\n  " "\n ewok`}</span>
    </footer>

  </div>
</Layout>
