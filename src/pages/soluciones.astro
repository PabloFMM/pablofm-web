---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import HighlightBox from "@/components/HighlightBox.astro";

const clusters = [
  {
    id: "C1",
    titulo: "Validación externa & burbuja fundacional",
    descripcion: "El sistema solo ha sido probado por sus creadores. No existe evidencia de que funcione para nadie más, en ningún contexto, sin que los fundadores estén ahí para explicarlo.",
    gaps: [
      { origen: "Negocio", label: "Ausencia de prueba de valor externa" },
      { origen: "Producto", label: "Burbuja fundacional / Sesgo de supervivencia inverso" },
      { origen: "Teoría", label: "Sesgo del fundador como único caso de prueba" },
    ],
    soluciones: [
      {
        titulo: "Experimento de exposición ciega",
        descripcion: "Diseñar un protocolo de onboarding de 48h sin intervención de fundadores: documentación sola, sin explicaciones orales, sin contexto previo. Medir cuánto comprende el participante, qué frustra y qué resuena. La primera persona que lo pase sola es la validación mínima real.",
        agentes: ["Negocio", "Producto"],
      },
      {
        titulo: "Embajador externo de confianza",
        descripcion: "Identificar una persona de confianza fuera de Numen Games (no del ecosistema cercano) con perfil target real —manager de equipo en empresa de 20-100 personas— y darle acceso completo durante 2 semanas. Su feedback sin filtrar es más valioso que 6 meses de análisis interno.",
        agentes: ["Negocio", "Teoría"],
      },
      {
        titulo: "Separar 'el sistema funciona' de 'nosotros funcionamos'",
        descripcion: "Diseñar un experimento controlado: el mismo equipo operando durante 4 semanas con NWOS y 4 semanas sin él, midiendo output, velocidad de decisión y engagement autopercibido. Si no hay diferencia medible, el sistema no está añadiendo valor — está el equipo.",
        agentes: ["Producto", "Teoría"],
      },
    ],
  },
  {
    id: "C2",
    titulo: "Complejidad de adopción & coste cognitivo",
    descripcion: "El vocabulario y las capas de abstracción del NWOS crean una barrera de entrada enorme. Lo que para los fundadores es fluido, para cualquier externo es un mundo completamente ajeno antes de obtener cualquier beneficio.",
    gaps: [
      { origen: "Negocio", label: "Complejidad de adopción vs. inercia organizacional" },
      { origen: "Producto", label: "Coste cognitivo de entrada vs. beneficio percibido" },
      { origen: "Teoría", label: "Carga cognitiva y brecha de traducción filosófica-práctica" },
    ],
    soluciones: [
      {
        titulo: "Mínimo Vocabulario Viable (MVV)",
        descripcion: "Identificar los 5 conceptos imprescindibles para que alguien sea operativo en su primer día. El resto puede llegar después. Si no puedes operar el sistema con 5 palabras, el sistema tiene demasiadas capas para su fase actual.",
        agentes: ["Producto", "Teoría"],
      },
      {
        titulo: "Capa de traducción corporativa",
        descripcion: "Crear un 'modo organización': las mismas estructuras del NWOS con vocabulario estándar (rol, proyecto, hito, equipo, decisión). El mundo narrativo de Numinia queda como capa profunda opcional, no como requisito de entrada. Mismo sistema, dos idiomas.",
        agentes: ["Negocio", "Producto"],
      },
      {
        titulo: "Onboarding progresivo con valor en cada paso",
        descripcion: "Reestructurar el onboarding para que cada nueva capa de vocabulario venga acompañada de un beneficio tangible inmediato. No se explica el sistema completo al principio: se revela a medida que la persona lo necesita. Inspirado en los mejores juegos de diseño progresivo.",
        agentes: ["Producto", "Teoría"],
      },
    ],
  },
  {
    id: "C3",
    titulo: "Modelo de negocio & comprador",
    descripcion: "No hay ICP definido, no hay línea de presupuesto clara, no hay modelo de monetización operativo. El NWOS podría ser SaaS, consultoría, metodología licenciada o formación — y esa ambigüedad en fase bootstrapping es letal.",
    gaps: [
      { origen: "Negocio", label: "El problema del comprador fantasma" },
      { origen: "Negocio", label: "Modelo de negocio indeterminado en fase crítica" },
      { origen: "Negocio", label: "Dependencia de evangelización vs. demanda orgánica" },
    ],
    soluciones: [
      {
        titulo: "Apostar por un solo segmento ahora",
        descripcion: "Elegir UN perfil de comprador para los próximos 6 meses y diseñar todo el go-to-market para él. Candidatos: CEO de startup de 15-50 personas que ya siente el problema de cultura, o CHRO de empresa tech que busca alternativa a los OKRs. La ambigüedad del ICP es el principal bloqueador de tracción.",
        agentes: ["Negocio"],
      },
      {
        titulo: "Buscar demanda existente, no crear demanda nueva",
        descripcion: "Mapear qué problemas están buscando resolver activamente las organizaciones hoy (herramientas de cultura, gestión del talento, onboarding de IA en equipos) y reformular el NWOS como solución a esos problemas. El mercado no busca 'Narrative Work OS' — busca retención, engagement y productividad.",
        agentes: ["Negocio"],
      },
      {
        titulo: "Modelo híbrido: consultoría primero, producto después",
        descripcion: "Las primeras 3 implementaciones externas como servicio de consultoría premium (no SaaS). Cada implementación genera aprendizaje sobre qué parte del sistema es realmente valiosa, qué se puede estandarizar y qué métrica usa el cliente para justificar el gasto. Ese conocimiento construye el producto.",
        agentes: ["Negocio", "Producto"],
      },
    ],
  },
  {
    id: "C4",
    titulo: "Accountability & ciudadanía digital",
    descripcion: "Equiparar LLMs y humanos en roles y misiones crea ambigüedad peligrosa sobre quién responde de qué. En organizaciones con estructura legal, HR y clientes externos, las cadenas de accountability tienen que ser inequívocas.",
    gaps: [
      { origen: "Producto", label: "Equivalencia LLM-Humano: el problema de accountability" },
      { origen: "Teoría", label: "Asimetría de agencia en la ciudadanía digital" },
    ],
    soluciones: [
      {
        titulo: "Ciudadanía diferenciada con responsabilidad humana explícita",
        descripcion: "Mantener la equivalencia narrativa (los agentes tienen rol, rango, misiones) pero añadir una capa de accountability: cada agente digital tiene un 'tutor humano' con nombre y apellidos que responde de sus decisiones. La narrativa iguala; el protocolo diferencia.",
        agentes: ["Producto", "Teoría"],
      },
      {
        titulo: "Protocolo de decisión con firma humana obligatoria",
        descripcion: "Definir qué categorías de decisiones requieren firma humana en las Piedras del Camino, independientemente de quién haya ejecutado el análisis. El agente digital propone, el humano firma. Esto preserva la coherencia del mundo sin borrar la cadena de responsabilidad.",
        agentes: ["Producto"],
      },
      {
        titulo: "Separar el plano narrativo del plano legal-operativo",
        descripcion: "Documentar explícitamente que la ciudadanía digital de los agentes existe en el plano narrativo (Numinia), no en el plano operativo (Numen Games S.L.). Los dos planos coexisten; uno no sustituye al otro. Esta separación hace el sistema defendible ante cualquier auditoría externa.",
        agentes: ["Negocio", "Teoría"],
      },
    ],
  },
  {
    id: "C5",
    titulo: "Autenticidad vs. performance & fatiga ritual",
    descripcion: "Los rituales y rangos pueden degenerar en teatro: participación formal sin implicación real. La investigación en psicología organizacional es clara — los sistemas de identidad impuesta producen surface acting, no transformación genuina.",
    gaps: [
      { origen: "Producto", label: "Fatiga ritual y teatro performativo" },
      { origen: "Teoría", label: "La trampa del cumplimiento performativo (surface acting)" },
    ],
    soluciones: [
      {
        titulo: "Rituales opt-in con efecto real sobre el sistema",
        descripcion: "Rediseñar los rituales para que la participación tenga consecuencias concretas en el estado del sistema (misiones desbloqueadas, decisiones activadas, recursos distribuidos), no solo valor simbólico. Cuando el ritual tiene peso operativo, la participación genuina y la performativa se distinguen solas.",
        agentes: ["Producto", "Teoría"],
      },
      {
        titulo: "Métricas de autenticidad vs. cumplimiento",
        descripcion: "Diseñar indicadores que distingan entre participación formal y engagement real: tiempo en el sistema fuera de rituales obligatorios, iniciativas no solicitadas, contribuciones al canon que nadie pidió. Si los únicos momentos de participación son los rituales, el sistema tiene un problema de motivación intrínseca.",
        agentes: ["Producto", "Teoría"],
      },
      {
        titulo: "Roles emergentes, no asignados",
        descripcion: "Cambiar la lógica de asignación de gremios y rangos: en lugar de ser asignados o elegidos al inicio, que emerjan de los patrones de comportamiento real en el sistema. Quien hace trabajo de Alquimista recibe el reconocimiento de Alquimista — no al revés. Esto elimina el incentivo al surface acting.",
        agentes: ["Teoría"],
      },
    ],
  },
  {
    id: "C6",
    titulo: "Métricas & demostrabilidad del valor",
    descripcion: "El sistema no tiene mecanismos propios para medir si está funcionando. Sin indicadores propios, no puede demostrar ROI, no puede detectar su propio deterioro y no puede diferenciarse de 'el equipo fundador es simplemente bueno'.",
    gaps: [
      { origen: "Producto", label: "Vacío métrico: ¿cómo sabe el sistema que funciona?" },
      { origen: "Negocio", label: "Riesgo de obsolescencia por commoditización de LLMs" },
    ],
    soluciones: [
      {
        titulo: "Dashboard de salud del sistema",
        descripcion: "Definir 5-7 indicadores propios del NWOS que vayan más allá del output de negocio estándar: velocidad media de cierre de misión, ratio de decisiones con documentación completa, participación en rituales vs. baseline, iniciativas bottom-up generadas, tiempo desde misión abierta hasta primer avance. Publicarlos internamente como contrato con uno mismo.",
        agentes: ["Producto", "Negocio"],
      },
      {
        titulo: "Moat metodológico, no tecnológico",
        descripcion: "Aceptar que la ventaja tecnológica de integrar LLMs es temporalmente efímera y apostar por el moat real: el cuerpo de conocimiento sobre cómo diseñar, implementar y mantener un NWOS en una organización real. Ese conocimiento tácito no se puede copiar con un producto. La diferencia entre leer sobre yoga y ser un profesor de yoga con 10 años de práctica.",
        agentes: ["Negocio"],
      },
      {
        titulo: "Casos de uso comparables como prueba de concepto",
        descripcion: "Documentar exhaustivamente el caso Numen Games como referencia: estado antes del NWOS (si se puede reconstruir), estado actual, indicadores concretos. Un caso real bien documentado vale más que 10 claims teóricos. Es el asset comercial más valioso que existe ahora mismo.",
        agentes: ["Negocio", "Producto"],
      },
    ],
  },
  {
    id: "C7",
    titulo: "Barrera cultural & universalismo no validado",
    descripcion: "El vocabulario esotérico genera rechazo en contextos corporativos tradicionales. El fundamento junguiano asume estructuras psicológicas universales que la investigación transcultural no confirma para todos los perfiles.",
    gaps: [
      { origen: "Negocio", label: "La metáfora como barrera de entrada" },
      { origen: "Negocio", label: "Credibilidad institucional: el muro del mundo corporativo" },
      { origen: "Teoría", label: "Universalismo junguiano vs. variación cultural y de personalidad" },
    ],
    soluciones: [
      {
        titulo: "Perfiles de compatibilidad explícita",
        descripcion: "Documentar para qué tipo de persona y organización el NWOS funciona mejor y para qué no. No intentar ser universal. El auto-filtrado es una fortaleza si es intencional: 'esto no es para todos' es una propuesta de valor, no una debilidad, si va dirigido al segmento correcto.",
        agentes: ["Negocio", "Teoría"],
      },
      {
        titulo: "Interfaz cultural configurable",
        descripcion: "Diseñar el NWOS con una capa superficial (vocabulario, nombres de rituales, estética narrativa) separable del núcleo estructural. Una organización japonesa o una firma de abogados pueden usar la misma gramática de roles/misiones/decisiones con su propio idioma cultural encima.",
        agentes: ["Producto", "Teoría"],
      },
      {
        titulo: "Validación empírica del fundamento teórico",
        descripcion: "En lugar de citar a Peirce y Jung como fundamento incuestionable, diseñar un protocolo de investigación mínimo que pruebe las hipótesis centrales: ¿los roles narrativos producen mayor identificación que los títulos corporativos? ¿Los rituales con nombre generan más cohesión que las reuniones estándar? Datos propios > citas de autoridad.",
        agentes: ["Teoría", "Negocio"],
      },
    ],
  },
  {
    id: "C8",
    titulo: "NWOS como analgésico & burnout estructural",
    descripcion: "El NWOS interviene sobre la dimensión de valores y comunidad del burnout, pero no toca carga, control ni justicia — que en la mayoría de organizaciones son los drivers primarios. Riesgo: proporciona significado narrativo que enmascara problemas estructurales sin resolverlos.",
    gaps: [
      { origen: "Teoría", label: "Malentendido causal sobre el burnout" },
      { origen: "Producto", label: "Coherencia narrativa no escala sin infraestructura" },
    ],
    soluciones: [
      {
        titulo: "Diagnóstico previo obligatorio",
        descripcion: "Antes de implementar el NWOS en cualquier organización, realizar un diagnóstico de las 6 dimensiones de Maslach. Si las dimensiones de carga, control o justicia están en rojo, documentar que el NWOS no es la intervención adecuada como primera capa. Esto protege al producto de ser culpado por problemas que no puede resolver.",
        agentes: ["Teoría"],
      },
      {
        titulo: "NWOS como amplificador, no como base",
        descripcion: "Reformular el claim del producto: el NWOS no resuelve el burnout estructural, lo amplifica cuando las condiciones estructurales son sanas. Es un multiplicador del engagement, no un sustituto de la gestión organizacional básica. Este reencuadre es más honesto y más defendible.",
        agentes: ["Negocio", "Teoría"],
      },
      {
        titulo: "Protocolo de mantenimiento del canon",
        descripcion: "Diseñar un rol explícito de 'guardián del canon' con autoridad reconocida para arbitrar interpretaciones divergentes del sistema a medida que escala. Sin ese rol, la coherencia narrativa se fragmenta inevitablemente por encima de 10-15 personas.",
        agentes: ["Producto"],
      },
    ],
  },
];

const agentColors: Record<string, string> = {
  Negocio: "bg-blue-500/10 text-blue-400 border-blue-500/30",
  Producto: "bg-purple-500/10 text-purple-400 border-purple-500/30",
  Teoría: "bg-teal-500/10 text-teal-400 border-teal-500/30",
};
---

<Layout
  title="NWOS — Soluciones — Pablo FM"
  description="Agrupación de gaps del Narrative Work OS y 3 soluciones propuestas por cluster. Firmadas por perspectiva de análisis."
  canonicalPath="/soluciones"
  activeNav=""
>
  <PageHero
    label="NWOS — Soluciones"
    title="De los puntos ciegos a las respuestas"
    description="20 gaps agrupados en 8 clusters. 3 soluciones por cluster. Cada solución firmada por el agente que la propone."
  />

  <!-- Intro -->
  <section class="pb-16">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="max-w-[720px] space-y-4 text-base leading-relaxed text-muted-foreground">
        <p>
          El análisis anterior identificó 20 gaps desde tres perspectivas críticas. Muchos de ellos apuntan al mismo problema desde ángulos distintos. Este documento los agrupa en <strong class="text-foreground">8 clusters</strong> y propone <strong class="text-foreground">3 soluciones por cluster</strong> — ordenadas de más inmediata a más estructural.
        </p>
        <p>
          Cada solución lleva la firma de los agentes que la proponen. No todas las perspectivas tienen la misma opinión sobre cada problema.
        </p>
      </div>

      <!-- Leyenda agentes -->
      <div class="mt-8 flex flex-wrap gap-3 text-xs">
        <span class="rounded-full border px-3 py-1 bg-blue-500/10 text-blue-400 border-blue-500/30 font-mono">Negocio</span>
        <span class="rounded-full border px-3 py-1 bg-purple-500/10 text-purple-400 border-purple-500/30 font-mono">Producto</span>
        <span class="rounded-full border px-3 py-1 bg-teal-500/10 text-teal-400 border-teal-500/30 font-mono">Teoría</span>
        <span class="ml-2 text-muted-foreground/60 self-center">— perspectivas que firman cada solución</span>
      </div>
    </div>
  </section>

  <!-- Clusters -->
  {clusters.map((cluster) => (
    <section class="border-t border-border py-16">
      <div class="mx-auto max-w-[1100px] px-6">
        <!-- Cluster header -->
        <div class="flex items-start gap-4 mb-8">
          <div class="shrink-0 rounded-lg border border-accent/30 bg-accent/5 px-3 py-1.5 font-mono text-xs text-accent">{cluster.id}</div>
          <div>
            <h2 class="font-display text-2xl text-foreground">{cluster.titulo}</h2>
            <p class="mt-2 max-w-[680px] text-sm text-muted-foreground">{cluster.descripcion}</p>
            <!-- Gaps origen -->
            <div class="mt-3 flex flex-wrap gap-2">
              {cluster.gaps.map((g) => (
                <span class={`rounded-full border px-2.5 py-0.5 text-[0.65rem] font-mono uppercase tracking-wider ${agentColors[g.origen]}`}>
                  {g.origen}: {g.label}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Soluciones -->
        <div class="grid gap-4 sm:grid-cols-3">
          {cluster.soluciones.map((s, i) => (
            <div class="rounded-xl border border-border bg-card p-5 space-y-3 flex flex-col">
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono text-muted-foreground/50">S{i + 1}</span>
                <h3 class="font-display text-sm text-foreground leading-snug">{s.titulo}</h3>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed flex-1">{s.descripcion}</p>
              <!-- Firmas -->
              <div class="flex flex-wrap gap-1.5 pt-2 border-t border-border/50">
                {s.agentes.map((a) => (
                  <span class={`rounded-full border px-2 py-0.5 text-[0.6rem] font-mono uppercase tracking-wider ${agentColors[a]}`}>
                    {a}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Cierre -->
  <section class="border-t border-border py-20">
    <div class="mx-auto max-w-[1100px] px-6">
      <HighlightBox>
        <p class="text-sm leading-relaxed text-muted-foreground">
          <strong class="text-accent">Prioridad de acción recomendada:</strong> Los clusters C1 (validación externa), C2 (complejidad de adopción) y C3 (modelo de negocio) son los únicos que bloquean todo lo demás. Sin validación externa, las soluciones a los otros clusters son prematura optimización. El resto — accountability digital, autenticidad ritual, métricas, barrera cultural, burnout estructural — son problemas de escala que solo se activan cuando hay algo que escalar.
        </p>
      </HighlightBox>
    </div>
  </section>
</Layout>
