---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import { eventos } from "@/data/eventos";

const estadoBadge: Record<string, { color: string; label: string; dot: string }> = {
  "en-curso": {
    color: "bg-accent/10 text-accent border-accent/30",
    label: "⚡ En curso",
    dot: "bg-accent",
  },
  "próximo": {
    color: "bg-yellow/10 text-yellow border-yellow/30",
    label: "🗓 Próximo",
    dot: "bg-yellow",
  },
  "pasado": {
    color: "bg-border/40 text-dim border-border",
    label: "✓ Pasado",
    dot: "bg-dim",
  },
};

const enCurso = eventos.filter((e) => e.estado === "en-curso");
const proximos = eventos.filter((e) => e.estado === "próximo");
const pasados = eventos.filter((e) => e.estado === "pasado");

function formatFecha(fecha: string, fechaFin?: string): string {
  const opts: Intl.DateTimeFormatOptions = { day: "numeric", month: "short", year: "numeric" };
  const d1 = new Date(fecha + "T12:00:00Z").toLocaleDateString("es-ES", opts);
  if (!fechaFin) return d1;
  const d2 = new Date(fechaFin + "T12:00:00Z").toLocaleDateString("es-ES", opts);
  return `${d1} – ${d2}`;
}
---

<Layout
  title="Eventos — Pablo FM / Numen Games"
  description="Histórico de eventos, conferencias y meetups a los que asiste Pablo FM y el equipo de Numen Games."
  canonicalPath="/eventos"
  activeNav="eventos"
>
  <PageHero
    label="Numen Games · Eventos"
    title="Eventos"
    description="Conferencias, meetups y encuentros del equipo de Numen Games. Cada evento es un nodo en la red."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Stats -->
      <div class="grid gap-4 sm:grid-cols-3 mb-12">
        <div class="rounded-xl border border-accent/20 bg-accent/5 p-5 text-center">
          <p class="font-display text-3xl text-accent">{enCurso.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">⚡ En curso</p>
        </div>
        <div class="rounded-xl border border-yellow/20 bg-yellow/5 p-5 text-center">
          <p class="font-display text-3xl text-yellow">{proximos.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">🗓 Próximos</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class="font-display text-3xl text-foreground">{pasados.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">✓ Pasados</p>
        </div>
      </div>

      <!-- En curso -->
      {enCurso.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3">
            <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">⚡ Aconteciendo ahora</span>
            <span class="h-px flex-1 bg-border"></span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {enCurso.map((e) => (
              <a
                href={`/eventos/${e.id}`}
                class="rounded-xl border border-accent/20 bg-accent/5 p-6 hover:bg-accent/10 transition-colors block"
              >
                <div class="flex items-start justify-between mb-3">
                  <span class:list={[
                    "inline-flex items-center gap-1.5 rounded-full border px-2.5 py-0.5 font-mono text-[0.6rem] font-medium",
                    estadoBadge[e.estado].color,
                  ]}>
                    <span class:list={["h-1.5 w-1.5 rounded-full animate-pulse", estadoBadge[e.estado].dot]}></span>
                    {estadoBadge[e.estado].label}
                  </span>
                  <span class="font-mono text-[0.6rem] text-dim">{e.ciudad}</span>
                </div>

                <h3 class="font-display text-xl text-foreground mb-1">{e.nombre}</h3>
                <p class="font-mono text-[0.65rem] text-accent mb-3">{formatFecha(e.fecha, e.fechaFin)}</p>
                <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-2">{e.descripcion}</p>

                <div class="border-t border-accent/10 pt-3">
                  <p class="font-mono text-[0.6rem] text-dim uppercase tracking-[0.15em] mb-1.5">Equipo</p>
                  <div class="flex flex-col gap-1">
                    {e.asistentes.map((a) => (
                      <span class="font-mono text-[0.65rem] text-foreground/80">· {a}</span>
                    ))}
                  </div>
                </div>

                <div class="mt-4 flex items-center justify-between">
                  <span class="font-mono text-[0.55rem] text-dim">{e.ubicacion}</span>
                  <span class="font-mono text-[0.6rem] text-accent">Ver detalle →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Próximos -->
      {proximos.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3">
            <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-yellow">🗓 Próximos eventos</span>
            <span class="h-px flex-1 bg-border"></span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {proximos.map((e) => (
              <a
                href={`/eventos/${e.id}`}
                class="rounded-xl border border-yellow/20 bg-yellow/5 p-5 hover:bg-yellow/10 transition-colors block"
              >
                <div class="flex items-start justify-between mb-3">
                  <span class:list={[
                    "inline-flex items-center gap-1.5 rounded-full border px-2.5 py-0.5 font-mono text-[0.6rem] font-medium",
                    estadoBadge[e.estado].color,
                  ]}>
                    <span class:list={["h-1.5 w-1.5 rounded-full", estadoBadge[e.estado].dot]}></span>
                    {estadoBadge[e.estado].label}
                  </span>
                  <span class="font-mono text-[0.6rem] text-dim">{e.ciudad}</span>
                </div>
                <h3 class="font-display text-lg text-foreground mb-1">{e.nombre}</h3>
                <p class="font-mono text-[0.65rem] text-yellow mb-3">{formatFecha(e.fecha, e.fechaFin)}</p>
                <p class="text-sm text-muted-foreground leading-relaxed mb-3 line-clamp-2">{e.descripcion}</p>
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[0.55rem] text-dim">{e.asistentes.length} asistentes</span>
                  <span class="font-mono text-[0.6rem] text-yellow">Ver →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Pasados -->
      {pasados.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3">
            <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">✓ Archivo — eventos pasados</span>
            <span class="h-px flex-1 bg-border"></span>
            <span class="font-mono text-[0.6rem] text-dim">{pasados.length} eventos</span>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {pasados.map((e) => (
              <a
                href={`/eventos/${e.id}`}
                class="rounded-xl border border-border bg-card p-5 hover:bg-card-hover transition-colors block"
              >
                <div class="flex items-start justify-between mb-3">
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-border px-2.5 py-0.5 font-mono text-[0.6rem] font-medium text-dim">
                    ✓ Pasado
                  </span>
                  <span class="font-mono text-[0.6rem] text-dim">{e.ciudad}</span>
                </div>
                <h3 class="font-display text-lg text-foreground mb-1">{e.nombre}</h3>
                <p class="font-mono text-[0.65rem] text-dim mb-3">{formatFecha(e.fecha, e.fechaFin)}</p>
                <p class="text-sm text-muted-foreground leading-relaxed mb-3 line-clamp-2">{e.descripcion}</p>
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[0.55rem] text-dim">{e.asistentes.length} asistentes</span>
                  <span class="font-mono text-[0.6rem] text-dim">Ver →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {eventos.length === 0 && (
        <div class="rounded-xl border border-border bg-card p-12 text-center">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">Sin eventos registrados</p>
          <p class="text-sm text-muted-foreground">Los eventos se añadirán aquí conforme ocurran.</p>
        </div>
      )}

      <!-- Nota -->
      <div class="mt-8 rounded-xl border border-border/50 bg-card/50 p-6">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">Sobre este registro</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Histórico de conferencias, meetups y encuentros del equipo de Numen Games.
          Cada evento documenta charlas, aprendizajes clave y contactos relevantes para la operación.
          Fuente: <code class="font-mono text-xs text-accent">src/data/eventos.ts</code>
        </p>
      </div>

    </div>
  </section>
</Layout>
