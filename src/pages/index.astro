---
import Layout from "@/layouts/Layout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import HighlightBox from "@/components/HighlightBox.astro";
import Tag from "@/components/Tag.astro";
import { getCollection } from "astro:content";
import { profile } from "@/data/profile";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const skills = [
  "Product Management",
  "Marketing Strategy",
  "Audio Engineering",
  "Video Production",
  "Startup Launch",
  "Seed Investing",
  "Mentoría",
  "Community Building",
  "Comunicación",
  "Audiovisual",
];
---

<Layout>
  <!-- Hero -->
  <section class="relative pb-16 pt-20 sm:pt-32">
    <div class="mx-auto max-w-[1100px] px-6">
      <span class="mb-4 inline-block font-mono text-[0.75rem] uppercase tracking-[0.2em] text-accent opacity-0 animate-slide-up">
        Emprendedor · Creador · Conector
      </span>

      <h1 class="font-display text-5xl tracking-tight text-foreground opacity-0 animate-slide-up-1 sm:text-7xl lg:text-8xl">
        Pablo <em class="text-accent">FM</em>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted-foreground opacity-0 animate-slide-up-2">
        Construyo cosas que conectan personas. Cofundador de Videona, inversor seed en BackFund, mentor en Tetuan Valley — y siempre montando algo nuevo.
      </p>

      <div class="mt-8 flex flex-wrap gap-3 opacity-0 animate-slide-up-3">
        <a
          href="/proyectos"
          class="inline-flex h-11 items-center gap-2 rounded-lg bg-accent px-6 text-sm font-semibold text-background transition-colors hover:bg-accent/90"
        >
          Ver proyectos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="/contacto"
          class="inline-flex h-11 items-center rounded-lg border border-border px-6 text-sm font-semibold text-foreground transition-colors hover:bg-card hover:text-accent"
        >
          Contacto
        </a>
      </div>

      <!-- Meta info -->
      <div class="mt-12 flex flex-wrap gap-8 font-mono text-[0.75rem] text-dim opacity-0 animate-slide-up-4">
        <div>Base <span class="text-muted-foreground">Madrid</span></div>
        <div>Focus <span class="text-muted-foreground">Startups & Producto</span></div>
        <div>Status <span class:list={[profile.statusActive ? "text-accent" : "text-muted-foreground"]}>{profile.status}</span></div>
      </div>
    </div>
  </section>

  <!-- Highlight -->
  <section class="border-t border-border py-16">
    <div class="mx-auto max-w-[1100px] px-6">
      <HighlightBox>
        <p class="text-sm leading-relaxed text-muted-foreground">
          <strong class="text-accent">Mi esencia:</strong> Constructor + Conector. No soy solo un emprendedor — soy alguien que crea cosas (productos, comunidades, experiencias) y conecta personas en el proceso. Este sitio es mi cuartel general digital.
        </p>
      </HighlightBox>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="border-t border-border py-16">
    <div class="mx-auto max-w-[1100px] px-6">
      <SectionHeader
        label="Proyectos destacados"
        title="Cosas que he montado"
        description="Algunos de los proyectos en los que he puesto más energía."
      />

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            role={project.data.role}
            href={project.data.href}
            tags={project.data.tags}
            status={project.data.status}
          />
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href="/proyectos"
          class="inline-flex items-center gap-2 font-mono text-sm text-muted-foreground transition-colors hover:text-accent"
        >
          Ver todos los proyectos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="border-t border-border py-16">
    <div class="mx-auto max-w-[1100px] px-6">
      <SectionHeader
        label="Skills"
        title="Lo que sé hacer"
      />

      <div class="mt-6 flex flex-wrap gap-2">
        {skills.map((skill) => (
          <Tag text={skill} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border py-20">
    <div class="mx-auto max-w-[1100px] px-6 text-center">
      <h2 class="font-display text-3xl text-foreground sm:text-4xl">
        ¿Hablamos?
      </h2>
      <p class="mx-auto mt-4 max-w-md text-muted-foreground">
        Si tienes un proyecto interesante, quieres colaborar o simplemente charlar — escríbeme.
      </p>
      <a
        href="/contacto"
        class="mt-8 inline-flex h-11 items-center gap-2 rounded-lg bg-accent px-6 text-sm font-semibold text-background transition-colors hover:bg-accent/90"
      >
        Contactar
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
