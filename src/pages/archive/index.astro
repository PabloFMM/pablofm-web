    max-height: 88vh;
  }
</style>

<script is:inline>
(function () {
  // Dialog open/close
  document.querySelectorAll('[data-dialog]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-dialog');
      var dlg = document.getElementById(id);
      if (dlg) dlg.showModal();
    });
  });
  document.querySelectorAll('[data-close-dialog]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var dlg = btn.closest('dialog');
      if (dlg) dlg.close();
    });
  });
  document.querySelectorAll('dialog.archive-dialog').forEach(function (dlg) {
    dlg.addEventListener('click', function (e) {
      if (e.target === dlg) dlg.close();
    });
  });

  // Three.js 3D diagram
  var nodesData = [
    { id: 'canon',      label: 'canon/',      subtitle: 'Memoria Inmutable',      color: 0x00ff88, x: 0,  y: 2,    z: 0,    relations: ['agents','missions'] },
    { id: 'agents',     label: 'agents/',     subtitle: 'Entidades Vivas',        color: 0x00d9c4, x: 2,  y: 0.5,  z: 1,    relations: ['missions'] },
    { id: 'missions',   label: 'missions/',   subtitle: 'Movimiento',             color: 0xffcc00, x: -2, y: 0.5,  z: 1,    relations: ['decisions','blueprints'] },
    { id: 'protocols',  label: 'protocols/',  subtitle: 'Rituales Operativos',    color: 0x4488ff, x: 0,  y: 0.5,  z: -2.5, relations: ['agents','missions'] },
    { id: 'decisions',  label: 'decisions/',  subtitle: 'Voluntad Cristalizada',  color: 0xaa44ff, x: 2,  y: -1,   z: -1,   relations: [] },
    { id: 'blueprints', label: 'blueprints/', subtitle: 'Potencial',              color: 0x8844cc, x: -2, y: -1,   z: -1,   relations: ['missions','protocols'] },
    { id: 'operations', label: 'operations/', subtitle: 'Sistema Circulatorio',   color: 0xff8800, x: 0,  y: -2,   z: 0.5,  relations: ['agents','missions'] },
  ];
  var edgesData = [
    ['canon','agents'], ['canon','missions'],
    ['protocols','agents'], ['protocols','missions'],
    ['operations','agents'], ['operations','missions'],
    ['missions','decisions'], ['missions','blueprints'],
    ['agents','missions'],
  ];

  function buildScene(THREE, el, w, h) {
    var scene = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(55, w / h, 0.1, 100);
    camera.position.set(0, 1, 7);

    var renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    el.appendChild(renderer.domElement);

    var group = new THREE.Group();
    scene.add(group);
    scene.add(new THREE.AmbientLight(0xffffff, 0.3));

    var meshMap = {};
    var posMap = {};

    nodesData.forEach(function (n) {
      var geo = new THREE.SphereGeometry(0.18, 20, 20);
      var mat = new THREE.MeshStandardMaterial({ color: n.color, emissive: n.color, emissiveIntensity: 0.6 });
      var mesh = new THREE.Mesh(geo, mat);
      mesh.position.set(n.x, n.y, n.z);
      mesh.userData = { label: n.label };
      group.add(mesh);
      meshMap[n.id] = mesh;
      posMap[n.id] = new THREE.Vector3(n.x, n.y, n.z);
      var light = new THREE.PointLight(n.color, 0.4, 3);
      light.position.copy(mesh.position);
      group.add(light);
    });

    edgesData.forEach(function (e) {
      var a = posMap[e[0]], b = posMap[e[1]];
      if (!a || !b) return;
      var geo = new THREE.BufferGeometry().setFromPoints([a.clone(), b.clone()]);
      var mat = new THREE.LineBasicMaterial({ color: 0x334155, opacity: 0.5, transparent: true });
      group.add(new THREE.Line(geo, mat));
    });

    // CSS2D labels — siempre visibles
    var labelRenderer = new (function CSS2DRenderer() {
      var domEl = document.createElement('div');
      domEl.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;overflow:hidden;width:100%;height:100%;';
      el.style.position = 'relative';
      el.appendChild(domEl);
      var labelEls = [];
      this.render = function(sc, cam) {
        // project each label
        labelEls.forEach(function(item) {
          var pos = item.pos.clone();
          group.localToWorld(pos);
          pos.project(cam);
          var x = (pos.x * 0.5 + 0.5) * el.offsetWidth;
          var y = (-pos.y * 0.5 + 0.5) * el.offsetHeight;
          item.el.style.transform = 'translate(-50%, -120%) translate(' + x + 'px,' + y + 'px)';
          item.el.style.display = pos.z < 1 ? 'block' : 'none';
        });
      };
      this.addLabel = function(text, subtitle, color, worldPos) {
        var div = document.createElement('div');
        div.style.cssText = 'position:absolute;top:0;left:0;font-family:monospace;text-align:center;pointer-events:none;';
        div.innerHTML = '<span style="display:block;font-size:10px;font-weight:bold;color:#' + color.toString(16).padStart(6,'0') + ';text-shadow:0 0 6px #000,0 0 3px #000;white-space:nowrap;">' + text + '</span>' +
          '<span style="display:block;font-size:8px;color:#aaa;text-shadow:0 0 4px #000;white-space:nowrap;">' + subtitle + '</span>';
        domEl.appendChild(div);
        labelEls.push({ el: div, pos: worldPos.clone() });
      };
    })();

    nodesData.forEach(function(n) {
      labelRenderer.addLabel(n.label, n.subtitle, n.color, posMap[n.id]);
    });

    // Panel de relaciones al hover
    var panel = document.createElement('div');
    panel.style.cssText = 'position:absolute;bottom:8px;left:8px;right:8px;background:rgba(0,0,0,0.75);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:8px 12px;font-family:monospace;font-size:11px;color:#fff;pointer-events:none;display:none;backdrop-filter:blur(4px);';
    el.appendChild(panel);

    var raycaster = new THREE.Raycaster();
    var mouse = new THREE.Vector2();
    var meshList = nodesData.map(function (n) { return meshMap[n.id]; });

    el.addEventListener('mousemove', function (ev) {
      var rect = el.getBoundingClientRect();
      mouse.x = ((ev.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((ev.clientY - rect.top) / rect.height) * 2 + 1;
      raycaster.setFromCamera(mouse, camera);
      var hits = raycaster.intersectObjects(meshList);
      if (hits.length > 0) {
        var nd = nodesData.find(function(n){ return meshMap[n.id] === hits[0].object; });
        if (nd) {
          var rels = nd.relations.length > 0 ? nd.relations.map(function(r){ return '<span style="color:#00d9c4">' + r + '/</span>'; }).join(', ') : '<span style="color:#666">ninguna saliente</span>';
          panel.innerHTML = '<strong style="color:#' + nd.color.toString(16).padStart(6,'0') + '">' + nd.label + '</strong> <span style="color:#aaa">' + nd.subtitle + '</span><br>Conecta con: ' + rels;
          panel.style.display = 'block';
        }
      } else {
        panel.style.display = 'none';
      }
    });
    el.addEventListener('mouseleave', function () {
      panel.style.display = 'none';
    });

    new ResizeObserver(function (entries) {
      var e = entries[0].contentRect;
      camera.aspect = e.width / e.height;
      camera.updateProjectionMatrix();
      renderer.setSize(e.width, e.height);
    }).observe(el);

    var clock = new THREE.Clock();
    (function animate() {
      requestAnimationFrame(animate);
      var t = clock.getElapsedTime();
      group.rotation.y = t * 0.18;
      group.rotation.x = Math.sin(t * 0.07) * 0.12;
      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    })();
  }

  import('https://esm.sh/three@0.163.0').then(function (THREE) {
    var el = document.getElementById('archive-3d');
    if (el) buildScene(THREE, el, el.offsetWidth || 400, 300);

    var modalInited = false;
    var openBtn = document.querySelector('[data-dialog="dialog-b"]');
    if (openBtn) {
      openBtn.addEventListener('click', function () {
        if (!modalInited) {
          setTimeout(function () {
            var mel = document.getElementById('archive-3d-modal');
            if (mel) { buildScene(THREE, mel, mel.offsetWidth || 600, 480); modalInited = true; }
          }, 60);
        }
      });
    }
  });
})();
</script>
