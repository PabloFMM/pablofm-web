---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";

const fondos = [
  {
    id: "canon",
    icon: "📜",
    nombre: "canon/",
    titulo: "Canon",
    lore: "Memoria Inmutable",
    descripcion: "Los 9 documentos fundacionales de Numinia. Inmutables por política y por técnica. Son el suelo sobre el que todo lo demás se construye.",
    funcion: "Límite operativo real. No referencia.",
    accent: "border-yellow/20 bg-yellow/5",
    accentText: "text-yellow",
    items: ["welcome-to-numinia.md", "epistemic-relations.md", "compendium-of-attributes.md", "role-structure.md", "platform-role-system.md", "about-session-zero.md", "numinia-el-juego-de-rol.md", "archive-system.md"],
  },
  {
    id: "agents",
    icon: "🤖",
    nombre: "agents/guilds/",
    titulo: "Agentes",
    lore: "Entidades Vivas",
    descripcion: "Los agentes digitales organizados por gremio. Cada uno con identidad (SOUL), reglas (OPERATOR) y estado operativo (STATUS).",
    funcion: "Identidad, capacidades y límites de cada agente.",
    accent: "border-accent/20 bg-accent/5",
    accentText: "text-accent",
    items: ["centinelas/", "exegetas/", "alquimistas/", "procuradores/", "coordinacion/"],
  },
  {
    id: "missions",
    icon: "⚡",
    nombre: "missions/",
    titulo: "Misiones",
    lore: "Movimiento",
    descripcion: "Las tareas con criterios de aceptación verificables. Unidad mínima de trabajo del sistema.",
    funcion: "Sin misión, no hay movimiento.",
    accent: "border-accent/20 bg-accent/5",
    accentText: "text-accent",
    items: ["active/", "done/", "backlog/"],
  },
  {
    id: "protocols",
    icon: "📋",
    nombre: "protocols/",
    titulo: "Protocolos",
    lore: "Rituales Operativos",
    descripcion: "Los 5 protocolos que estandarizan el comportamiento: briefing, onboarding, ciclo-misión, inter-agent y escalation.",
    funcion: "Eliminar ambigüedad. La urgencia es el enemigo del protocolo.",
    accent: "border-border bg-card",
    accentText: "text-foreground",
    items: ["P-001", "P-002", "P-003", "P-004", "P-005"],
  },
  {
    id: "decisions",
    icon: "🗿",
    nombre: "decisions/",
    titulo: "Decisiones",
    lore: "Voluntad Cristalizada",
    descripcion: "Los ADRs del sistema. Append-only — las decisiones no se borran, se superseden.",
    funcion: "Preservar la intención original de cada decisión.",
    accent: "border-border bg-card",
    accentText: "text-foreground",
    items: ["ADR-001.md", "ADR-002.md", "ADR-NNN.md"],
  },
  {
    id: "blueprints",
    icon: "🔮",
    nombre: "blueprints/",
    titulo: "Blueprints",
    lore: "Potencial No Manifestado",
    descripcion: "Diseños y arquitecturas que aún no han tomado forma. El espacio donde las ideas viven antes de convertirse en misiones.",
    funcion: "Capturar intención antes de que se pierda.",
    accent: "border-border bg-card",
    accentText: "text-foreground",
    items: ["future-agents/", "system-extensions/", "experiments/"],
  },
  {
    id: "operations",
    icon: "⚙️",
    nombre: "operations/",
    titulo: "Operaciones",
    lore: "Sistema Circulatorio",
    descripcion: "Governance, security y credential-map. El tejido conectivo que mantiene el sistema operativo y seguro.",
    funcion: "Coordinar sin colisionar. Asegurar sin bloquear.",
    accent: "border-border bg-card",
    accentText: "text-foreground",
    items: ["governance.md", "security.md", "credential-map.md"],
  },
];

const principios = [
  { id: "P-01", texto: "El README no es documentación. Es orientación ontológica.", sim: "Sim-001" },
  { id: "P-02", texto: "La estructura fija permite arranques eficientes.", sim: "Sim-003" },
  { id: "P-03", texto: "El CHANGELOG es el punto de resincronización temporal.", sim: "Sim-007" },
  { id: "P-04", texto: "El rol define el orden de lectura en el arranque.", sim: "Sim-012" },
  { id: "P-05", texto: "La urgencia es el mayor enemigo del protocolo.", sim: "Sim-019" },
  { id: "P-06", texto: "git pull es el primer paso ritual. Siempre.", sim: "Sim-023" },
  { id: "P-07", texto: "El canon no es referencia. Es límite operativo real.", sim: "Sim-031" },
  { id: "P-08", texto: "El estado blocked es tan importante como done.", sim: "Sim-044" },
  { id: "P-09", texto: "Las misiones deben ser self-contained.", sim: "Sim-056" },
  { id: "P-10", texto: "El aprendizaje vive en la divergencia (divergence_log).", sim: "Sim-067" },
  { id: "P-11", texto: "Los guilds tienen scope. Las misiones respetan guild boundaries.", sim: "Sim-078" },
  { id: "P-12", texto: "Reads son safe; writes requieren coordinación.", sim: "Sim-091" },
];

const fallos = [
  {
    id: "F-01", nombre: "Canon Drift", icono: "🛡",
    qué: "Alguien edita canon/ sin pasar por el protocolo de validación oracle.",
    impacto: "Pérdida de la identidad canónica del sistema. Todos los agentes operan sobre base corrupta.",
    prevención: "CODEOWNERS bloqueante en canon/. Sin oracle review, el PR no hace merge.",
  },
  {
    id: "F-02", nombre: "Template Drift", icono: "🔄",
    qué: "Agentes usan templates obsoletos para crear misiones o reportes.",
    impacto: "Inconsistencia estructural. Misiones que no pueden ser parseadas por otros agentes.",
    prevención: "Versión en el header de cada template. CI falla si el schema no coincide.",
  },
  {
    id: "F-03", nombre: "Oracle como SPOF", icono: "⏱",
    qué: "El sistema se paraliza porque el oracle no responde en <48h.",
    impacto: "Todo el pipeline bloqueado. Los agentes no pueden avanzar en misiones críticas.",
    prevención: "Timeout 48h: si no hay respuesta, el agente escala al siguiente nivel de la jerarquía.",
  },
  {
    id: "F-04", nombre: "Credenciales en Commits", icono: "🔐",
    qué: "Un agente incluye tokens, API keys o secretos en un commit.",
    impacto: "Exposición de credenciales en un repositorio que puede hacerse público.",
    prevención: "pre-commit hook obligatorio con git-secrets o similar. CI bloquea el merge.",
  },
  {
    id: "F-05", nombre: "Deriva Semántica del Canon", icono: "📅",
    qué: "El canon pierde significado porque nadie lo revisa y la realidad operativa diverge.",
    impacto: "Los agentes operan en un sistema diferente al que el canon describe.",
    prevención: "Revisión cuatrimestral obligatoria del canon. ADR si algo cambia.",
  },
];

const fases = [
  {
    fase: "Alpha", periodo: "Ahora — Mes 1", estado: "activa",
    criterioSalida: "10 misiones completadas · 0 incidentes de seguridad · 20 arranques canónicos exitosos",
    descripcion: "Todo bajo supervisión oracle. Ningún agente opera sin validación explícita.",
    color: "border-accent/30 bg-accent/5", badge: "bg-accent/10 text-accent",
  },
  {
    fase: "Beta", periodo: "Mes 2–3", estado: "pendiente",
    criterioSalida: "30 misiones autónomas · Procyon activo · ciclo <48h sin oracle",
    descripcion: "Nimrod autónomo en su dominio. Los Centinelas operan con delegación parcial.",
    color: "border-border bg-card", badge: "bg-border text-dim",
  },
  {
    fase: "v1.0.0", periodo: "Mes 4–6", estado: "pendiente",
    criterioSalida: "Sistema autónomo · SLA documentado · Protocolo de expansión activo",
    descripcion: "El sistema opera de forma autónoma. Oracle como árbitro de último recurso.",
    color: "border-border bg-card", badge: "bg-border text-dim",
  },
];

const arranqueSteps = [
  { n: "01", cmd: "git pull origin main", desc: "Sincronización ritual. Siempre el primero." },
  { n: "02", cmd: "cat CHANGELOG.md | head -50", desc: "Punto de resincronización temporal." },
  { n: "03", cmd: "cat agents/guilds/{tu-gremio}/README.md", desc: "Tu rol define tu orden de lectura." },
  { n: "04", cmd: "ls missions/active/", desc: "¿Qué está en movimiento? Aquí empieza la sesión." },
];
---

<Layout
  title="Archive Summa — El Sistema Nervioso de Numinia · Numen Games"
  description="El repositorio numinia-agents como fuente de verdad canónica del sistema de agentes digitales. 7 fondos documentales, 12 principios operativos, 100 simulaciones."
  canonicalPath="/archive"
  activeNav="archive"
>
  <PageHero
    label="CAO · Archive Summa"
    title="Archive Summa"
    description="Este repositorio no documenta el sistema. Es el lugar donde el sistema ocurre."
  />

  <section class="pb-24">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Stats -->
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-4 mb-16">
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class="font-display text-4xl text-foreground">7</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Fondos documentales</p>
        </div>
        <div class="rounded-xl border border-accent/20 bg-accent/5 p-5 text-center">
          <p class="font-display text-4xl text-accent">12</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Principios operativos</p>
        </div>
        <div class="rounded-xl border border-red/20 bg-red/5 p-5 text-center">
          <p class="font-display text-4xl text-red">5</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Fallos críticos id.</p>
        </div>
        <div class="rounded-xl border border-green/20 bg-green/5 p-5 text-center">
          <p class="font-display text-4xl text-green">100</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Simulaciones mentales</p>
        </div>
      </div>

      <!-- Diagramas -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Mapas del sistema</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 mb-12">
        <!-- Diagrama A: SVG hardcodeado -->
        <div class="rounded-xl border border-border bg-card p-6">
          <div class="flex items-center justify-between mb-2">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">Diagrama A — Ciclo del agente</p>
            <button data-dialog="dialog-a" class="font-mono text-[0.55rem] uppercase tracking-wider text-dim hover:text-accent transition-colors border border-border/50 rounded px-2 py-0.5 hover:border-accent/30">
              Expandir ↗
            </button>
          </div>
          <p class="text-xs text-muted-foreground mb-4">El recorrido que vive un agente en cada sesión</p>
          <svg viewBox="0 0 320 520" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[280px] mx-auto" style="font-family:monospace;font-size:9px" aria-label="Ciclo del agente">
            <defs>
              <marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                <path d="M0,0 L0,6 L6,3 z" fill="#00d9c4"/>
              </marker>
            </defs>
            <rect x="95" y="10" width="130" height="28" rx="14" fill="#001a14" stroke="#00d9c4" stroke-width="1.2"/>
            <text x="160" y="28" text-anchor="middle" fill="#00d9c4">git pull</text>
            <rect x="95" y="60" width="130" height="28" rx="6" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="160" y="78" text-anchor="middle" fill="#94a3b8">SOUL.md</text>
            <rect x="95" y="110" width="130" height="28" rx="6" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="160" y="128" text-anchor="middle" fill="#94a3b8">OPERATOR.md</text>
            <polygon points="160,158 220,185 160,212 100,185" fill="#0d1f33" stroke="#334155" stroke-width="1"/>
            <text x="160" y="183" text-anchor="middle" fill="#94a3b8">Misión</text>
            <text x="160" y="194" text-anchor="middle" fill="#94a3b8">asignada?</text>
            <rect x="195" y="228" width="110" height="26" rx="5" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="250" y="245" text-anchor="middle" fill="#94a3b8">missions/active/</text>
            <rect x="15" y="228" width="110" height="26" rx="5" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="70" y="245" text-anchor="middle" fill="#94a3b8">missions/backlog/</text>
            <rect x="95" y="278" width="130" height="26" rx="5" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="160" y="295" text-anchor="middle" fill="#94a3b8">Ejecutar</text>
            <polygon points="160,322 220,348 160,374 100,348" fill="#0d1f33" stroke="#334155" stroke-width="1"/>
            <text x="160" y="346" text-anchor="middle" fill="#94a3b8">Divergencia?</text>
            <rect x="230" y="384" width="80" height="26" rx="5" fill="#2d0011" stroke="#ff2d55" stroke-width="1"/>
            <text x="270" y="401" text-anchor="middle" fill="#ff2d55">diverg_log</text>
            <rect x="95" y="384" width="110" height="26" rx="5" fill="#0a1628" stroke="#334155" stroke-width="1"/>
            <text x="150" y="401" text-anchor="middle" fill="#94a3b8">commit + PR</text>
            <polygon points="160,424 215,447 160,470 105,447" fill="#0d1f33" stroke="#334155" stroke-width="1"/>
            <text x="160" y="445" text-anchor="middle" fill="#94a3b8">Oracle</text>
            <text x="160" y="456" text-anchor="middle" fill="#94a3b8">aprueba?</text>
            <rect x="95" y="478" width="130" height="28" rx="14" fill="#001a14" stroke="#00d9c4" stroke-width="1.2"/>
            <text x="160" y="496" text-anchor="middle" fill="#00d9c4">merge ✓</text>
            <line x1="160" y1="38" x2="160" y2="58" stroke="#00d9c4" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="160" y1="88" x2="160" y2="108" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="160" y1="138" x2="160" y2="156" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="220" y1="185" x2="250" y2="185" stroke="#334155" stroke-width="1"/>
            <line x1="250" y1="185" x2="250" y2="226" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <text x="228" y="181" fill="#64748b" font-size="7">Sí</text>
            <line x1="100" y1="185" x2="70" y2="185" stroke="#334155" stroke-width="1"/>
            <line x1="70" y1="185" x2="70" y2="226" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <text x="75" y="181" fill="#64748b" font-size="7">No</text>
            <line x1="250" y1="254" x2="250" y2="268" stroke="#334155" stroke-width="1"/>
            <line x1="250" y1="268" x2="182" y2="276" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="70" y1="254" x2="70" y2="268" stroke="#334155" stroke-width="1"/>
            <line x1="70" y1="268" x2="138" y2="276" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="160" y1="304" x2="160" y2="320" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="220" y1="348" x2="270" y2="348" stroke="#ff2d55" stroke-width="1"/>
            <line x1="270" y1="348" x2="270" y2="382" stroke="#ff2d55" stroke-width="1" marker-end="url(#arr)"/>
            <text x="225" y="344" fill="#ff2d55" font-size="7">Sí</text>
            <line x1="230" y1="397" x2="207" y2="397" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="100" y1="348" x2="70" y2="348" stroke="#334155" stroke-width="1"/>
            <line x1="70" y1="348" x2="70" y2="397" stroke="#334155" stroke-width="1"/>
            <line x1="70" y1="397" x2="93" y2="397" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <text x="75" y="344" fill="#64748b" font-size="7">No</text>
            <line x1="160" y1="410" x2="160" y2="422" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <line x1="160" y1="470" x2="160" y2="476" stroke="#00d9c4" stroke-width="1" marker-end="url(#arr)"/>
            <text x="165" y="474" fill="#00d9c4" font-size="7">Sí</text>
            <line x1="215" y1="447" x2="298" y2="447" stroke="#334155" stroke-width="1"/>
            <line x1="298" y1="447" x2="298" y2="291" stroke="#334155" stroke-width="1"/>
            <line x1="298" y1="291" x2="227" y2="291" stroke="#334155" stroke-width="1" marker-end="url(#arr)"/>
            <text x="218" y="443" fill="#64748b" font-size="7">No→</text>
          </svg>
        </div>

        <!-- Diagrama B: Three.js 3D -->
        <div class="rounded-xl border border-border bg-card p-6 relative">
          <div class="flex items-center justify-between mb-2">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">Diagrama B — Relaciones entre fondos</p>
            <button data-dialog="dialog-b" class="font-mono text-[0.55rem] uppercase tracking-wider text-dim hover:text-accent transition-colors border border-border/50 rounded px-2 py-0.5 hover:border-accent/30">
              Expandir ↗
            </button>
          </div>
          <p class="text-xs text-muted-foreground mb-4">Cómo se relacionan los 7 fondos documentales</p>
          <div id="archive-3d" style="width:100%;height:300px;"></div>
          <div id="archive-3d-tooltip" style="position:absolute;display:none;pointer-events:none;" class="font-mono text-[0.65rem] text-accent bg-black/80 border border-accent/30 rounded px-2 py-1 z-10 whitespace-nowrap"></div>
        </div>
      </div>

      <!-- Los 7 Fondos — clickables -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Los 7 fondos documentales</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 mb-16">
        {fondos.map((f) => (
          <a href={`/archive/${f.id}`} class={`rounded-xl border p-5 ${f.accent} hover:border-accent/50 transition-all group block`}>
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl">{f.icon}</span>
              <span class={`font-mono text-[0.55rem] uppercase tracking-[0.15em] ${f.accentText} opacity-70`}>{f.lore}</span>
            </div>
            <h3 class={`font-mono text-sm font-medium mb-1 ${f.accentText}`}>{f.nombre}</h3>
            <p class="text-xs text-muted-foreground leading-relaxed mb-3">{f.descripcion}</p>
            <div class="border-t border-border/50 pt-3">
              <p class="font-mono text-[0.6rem] text-dim italic">{f.funcion}</p>
            </div>
            <div class="mt-3 flex flex-wrap gap-1">
              {f.items.map((item) => (
                <span class="font-mono text-[0.5rem] bg-background/50 border border-border/50 rounded px-1.5 py-0.5 text-dim">{item}</span>
              ))}
            </div>
            <p class="mt-3 font-mono text-[0.55rem] text-accent opacity-0 group-hover:opacity-100 transition-opacity">Ver fondo →</p>
          </a>
        ))}
      </div>

      <!-- Arranque Canónico -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Protocolo de arranque canónico</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6 mb-16">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-5">4 pasos. Sin excepción. Sin atajos.</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {arranqueSteps.map((step) => (
            <div class="rounded-lg border border-border/50 bg-background/60 p-4">
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-[0.65rem] text-accent font-bold">{step.n}</span>
                <code class="font-mono text-xs text-foreground bg-black/20 rounded px-2 py-0.5 flex-1">{step.cmd}</code>
              </div>
              <p class="font-mono text-[0.6rem] text-dim pl-6">{step.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-mono text-[0.6rem] text-dim mt-4 italic">
          P-06: git pull es el primer paso ritual. Siempre. · P-03: El CHANGELOG es el punto de resincronización temporal.
        </p>
      </div>

      <!-- Jerarquía de Delegación -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Jerarquía de delegación</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 mb-16">
        {fases.map((f) => (
          <div class={`rounded-xl border p-6 ${f.color}`}>
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-display text-2xl text-foreground">{f.fase}</h3>
              <span class={`inline-flex rounded-full px-2 py-0.5 font-mono text-[0.55rem] font-medium ${f.badge}`}>
                {f.estado === "activa" ? "● activa" : "○ pendiente"}
              </span>
            </div>
            <p class="font-mono text-[0.65rem] text-dim mb-3">{f.periodo}</p>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">{f.descripcion}</p>
            <div class="border-t border-border/50 pt-4">
              <p class="font-mono text-[0.55rem] text-dim uppercase tracking-[0.1em] mb-1">Criterios de salida</p>
              <p class="font-mono text-[0.6rem] text-foreground leading-relaxed">{f.criterioSalida}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Principios Operativos — accordion -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Principios operativos</span>
        <span class="h-px flex-1 bg-border"></span>
