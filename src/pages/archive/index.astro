  }
  .archive-dialog-inner {
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow: auto;
    max-height: 85vh;
  }
  details[open] summary .summary-arrow {
    transform: rotate(180deg);
  }
</style>

<script is:inline>
  // Dialog open/close
  document.querySelectorAll('[data-dialog]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = btn.getAttribute('data-dialog');
      var dialog = document.getElementById(id);
      if (dialog) dialog.showModal();
    });
  });
  document.querySelectorAll('[data-close-dialog]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var dialog = btn.closest('dialog');
      if (dialog) dialog.close();
    });
  });
  document.querySelectorAll('dialog').forEach(function(dialog) {
    dialog.addEventListener('click', function(e) {
      if (e.target === dialog) dialog.close();
    });
  });

  // Three.js 3D diagram
  (function() {
    var container = document.getElementById('archive-3d');
    if (!container) return;

    import('https://esm.sh/three@0.163.0').then(function(THREE) {

      var nodesData = [
        { id: 'canon',      label: 'canon/',      color: 0x00ff88, x: 0,  y: 2,    z: 0   },
        { id: 'agents',     label: 'agents/',     color: 0x00d9c4, x: 2,  y: 0.5,  z: 1   },
        { id: 'missions',   label: 'missions/',   color: 0xffcc00, x: -2, y: 0.5,  z: 1   },
        { id: 'protocols',  label: 'protocols/',  color: 0x4488ff, x: 0,  y: 0.5,  z: -2.5},
        { id: 'decisions',  label: 'decisions/',  color: 0xaa44ff, x: 2,  y: -1,   z: -1  },
        { id: 'blueprints', label: 'blueprints/', color: 0x8844cc, x: -2, y: -1,   z: -1  },
        { id: 'operations', label: 'operations/', color: 0xff8800, x: 0,  y: -2,   z: 0.5 },
      ];

      var edgesData = [
        ['canon', 'agents'], ['canon', 'missions'],
        ['protocols', 'agents'], ['protocols', 'missions'],
        ['operations', 'agents'], ['operations', 'missions'],
        ['missions', 'decisions'], ['missions', 'blueprints'],
        ['agents', 'missions'],
      ];

      function initScene(el, width, height) {
        var scene = new THREE.Scene();
        var camera = new THREE.PerspectiveCamera(55, width / height, 0.1, 100);
        camera.position.set(0, 1, 7);

        var renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);
        el.appendChild(renderer.domElement);

        var group = new THREE.Group();
        scene.add(group);

        var nodeMeshes = {};
        var nodePositions = {};

        // Create nodes
        nodesData.forEach(function(n) {
          var geo = new THREE.SphereGeometry(0.18, 20, 20);
          var mat = new THREE.MeshStandardMaterial({ color: n.color, emissive: n.color, emissiveIntensity: 0.6 });
          var mesh = new THREE.Mesh(geo, mat);
          mesh.position.set(n.x, n.y, n.z);
          mesh.userData = { label: n.label, id: n.id };
          group.add(mesh);
          nodeMeshes[n.id] = mesh;
          nodePositions[n.id] = new THREE.Vector3(n.x, n.y, n.z);

          var light = new THREE.PointLight(n.color, 0.4, 3);
          light.position.set(n.x, n.y, n.z);
          group.add(light);
        });

        // Create edges
        edgesData.forEach(function(e) {
          var a = nodePositions[e[0]];
          var b = nodePositions[e[1]];
          if (!a || !b) return;
          var points = [a.clone(), b.clone()];
          var geo = new THREE.BufferGeometry().setFromPoints(points);
          var mat = new THREE.LineBasicMaterial({ color: 0x334155, opacity: 0.5, transparent: true });
          var line = new THREE.Line(geo, mat);
          group.add(line);
        });

        // Ambient light
        scene.add(new THREE.AmbientLight(0xffffff, 0.3));

        // Raycaster for hover tooltip
        var raycaster = new THREE.Raycaster();
        var mouse = new THREE.Vector2();
        var tooltip = document.getElementById('archive-3d-tooltip');
        var hoveredNode = null;

        el.addEventListener('mousemove', function(ev) {
          var rect = el.getBoundingClientRect();
          mouse.x = ((ev.clientX - rect.left) / rect.width) * 2 - 1;
          mouse.y = -((ev.clientY - rect.top) / rect.height) * 2 + 1;

          raycaster.setFromCamera(mouse, camera);
          var meshList = nodesData.map(function(n) { return nodeMeshes[n.id]; });
          var intersects = raycaster.intersectObjects(meshList);

          if (intersects.length > 0) {
            var obj = intersects[0].object;
            if (tooltip) {
              tooltip.textContent = obj.userData.label;
              tooltip.style.display = 'block';
              tooltip.style.left = (ev.clientX - el.getBoundingClientRect().left + 12) + 'px';
              tooltip.style.top = (ev.clientY - el.getBoundingClientRect().top - 8) + 'px';
            }
            hoveredNode = obj;
          } else {
            if (tooltip) tooltip.style.display = 'none';
            hoveredNode = null;
          }
        });

        el.addEventListener('mouseleave', function() {
          if (tooltip) tooltip.style.display = 'none';
          hoveredNode = null;
        });

        // Responsive
        var resizeObserver = new ResizeObserver(function(entries) {
          for (var entry of entries) {
            var w = entry.contentRect.width;
            var h = entry.contentRect.height;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h);
          }
        });
        resizeObserver.observe(el);

        // Animation
        var clock = new THREE.Clock();
        function animate() {
          requestAnimationFrame(animate);
          var t = clock.getElapsedTime();
          group.rotation.y = t * 0.18;
          group.rotation.x = Math.sin(t * 0.07) * 0.12;
          renderer.render(scene, camera);
        }
        animate();

        return { scene: scene, renderer: renderer, camera: camera, group: group };
      }

      // Init inline diagram
      var w = container.offsetWidth || 400;
      var h = 320;
      initScene(container, w, h);

      // Init modal diagram when dialog opens
      var dialogB = document.getElementById('dialog-b');
      var modalInited = false;
      if (dialogB) {
        dialogB.addEventListener('toggle', function() {
          if (!modalInited && dialogB.open) {
            var modalContainer = document.getElementById('archive-3d-modal');
            if (modalContainer) {
              var mw = modalContainer.offsetWidth || 600;
              initScene(modalContainer, mw, 500);
              modalInited = true;
            }
          }
        });
        // Fallback: listen to the open button
        var openBtn = document.querySelector('[data-dialog="dialog-b"]');
        if (openBtn) {
          openBtn.addEventListener('click', function() {
            setTimeout(function() {
              if (!modalInited) {
                var modalContainer = document.getElementById('archive-3d-modal');
                if (modalContainer) {
                  var mw = modalContainer.offsetWidth || 600;
                  initScene(modalContainer, mw, 500);
                  modalInited = true;
                }
              }
            }, 50);
          });
        }
      }
    });
  })();
</script>
