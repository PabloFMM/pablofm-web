---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import { decisiones, pendientesDecisiones } from "@/data/decisiones";

const estadoColor: Record<string, string> = {
  activa: "bg-green/10 text-green",
  provisional: "bg-yellow/10 text-yellow",
  supersedida: "bg-muted text-muted-foreground",
};
const estadoLabel: Record<string, string> = {
  activa: "Activa", provisional: "Provisional", supersedida: "Supersedida",
};
---

<Layout
  title="Decisiones — Piedras del Camino · Numen Games"
  description="Registro de decisiones arquitectónicas y estratégicas de Numen Games. El por qué de cómo construimos Numinia."
  canonicalPath="/decisiones"
  activeNav="decisiones"
>
  <PageHero
    label="CAO · Registro Akáshico"
    title="Decisiones"
    description="Las piedras del camino. Cada decisión captura el contexto, el por qué y las alternativas descartadas."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">

      <!-- Stats -->
      <div class="grid gap-4 sm:grid-cols-3 mb-12">
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class="font-display text-3xl text-foreground">{decisiones.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Decisiones tomadas</p>
        </div>
        <div class="rounded-xl border border-yellow/20 bg-yellow/5 p-5 text-center">
          <p class="font-display text-3xl text-yellow">{decisiones.filter(d => d.pendienteDarkCouncil).length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">🟡 Pendientes Dark Council</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class="font-display text-3xl text-foreground">{pendientesDecisiones.length}</p>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim mt-1">Por tomar</p>
        </div>
      </div>

      <!-- Lista de decisiones -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Decisiones registradas</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="space-y-4 mb-12">
        {decisiones.map((d) => (
          <a href={`/decisiones/${d.id.toLowerCase()}`} class="block rounded-xl border border-border bg-card p-6 hover:bg-card-hover transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="font-mono text-[0.65rem] text-dim">{d.id}</span>
                  <span class:list={["inline-flex rounded-full px-2.5 py-0.5 font-mono text-[0.6rem] font-medium", estadoColor[d.estado]]}>
                    {estadoLabel[d.estado]}
                  </span>
                  {d.pendienteDarkCouncil && (
                    <span class="inline-flex rounded-full bg-yellow/10 px-2.5 py-0.5 font-mono text-[0.6rem] text-yellow">
                      Dark Council
                    </span>
                  )}
                  <span class="font-mono text-[0.6rem] text-dim">{d.area}</span>
                </div>
                <h3 class="font-display text-xl text-foreground mb-2">{d.titulo}</h3>
                <p class="text-sm text-muted-foreground leading-relaxed">{d.decision}</p>
              </div>
              <div class="flex-shrink-0 text-right">
                <p class="font-mono text-[0.65rem] text-dim">{d.fecha}</p>
                <p class="font-mono text-[0.65rem] text-accent mt-2">Ver →</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pendientes de tomar -->
      <div class="mb-4 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-dim">Pendientes de tomar — Dark Council lunes</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 mb-12">
        {pendientesDecisiones.map((p) => (
          <div class="rounded-xl border border-border/50 bg-card/50 p-5">
            <div class="flex items-start justify-between gap-2 mb-2">
              <span class:list={["font-mono text-[0.6rem]", p.urgencia === "Alta" ? "text-red" : p.urgencia === "Media" ? "text-yellow" : "text-dim"]}>
                {p.urgencia === "Alta" ? "🔴" : p.urgencia === "Media" ? "🟡" : "🟢"} {p.urgencia}
              </span>
              <span class="font-mono text-[0.55rem] text-dim">{p.area}</span>
            </div>
            <p class="text-sm text-muted-foreground">{p.titulo}</p>
          </div>
        ))}
      </div>

      <!-- Nota -->
      <div class="rounded-xl border border-border/50 bg-card/50 p-6">
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-2">Sobre las Decisiones</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Las decisiones no se modifican — se superseden. Si el criterio cambia, se añade una nueva decisión que reemplaza a la anterior. El historial completo siempre es visible.
        </p>
      </div>

    </div>
  </section>
</Layout>
