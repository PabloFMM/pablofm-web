---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import { socialLinks } from "@/data/social-links";

const CAL_URL = "http://161.35.215.224:3002/pablofm";
---

<Layout
  title="Contacto — Pablo FM"
  description="¿Tienes un proyecto, una idea o simplemente quieres charlar? Reserva una llamada directamente."
  canonicalPath="/contacto"
  activeNav="contacto"
>
  <PageHero
    label="Contacto"
    title="Hablamos"
    description="Sin formularios. Sin esperas. Reserva directamente en mi calendario."
  />

  <section class="pb-20">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="grid gap-12 lg:grid-cols-5">

        <!-- CTA Principal -->
        <div class="lg:col-span-3">
          <div class="rounded-xl border border-border bg-card p-8">
            <div class="mb-6">
              <span class="inline-block rounded-full bg-accent/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent">
                Disponible
              </span>
            </div>

            <h2 class="font-display text-2xl text-foreground">
              Reserva una llamada
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              30 minutos para hablar de tu proyecto, explorar una colaboración o simplemente conocernos. Sin compromisos.
            </p>

            <a
              href={CAL_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex h-12 items-center gap-3 rounded-lg bg-accent px-8 text-sm font-semibold text-background transition-colors hover:bg-accent/90"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Reservar llamada
            </a>

            <p class="mt-4 font-mono text-xs text-dim">
              Powered by Cal.com · Self-hosted · Sin cookies
            </p>
          </div>

          <!-- Email directo -->
          <div class="mt-4 rounded-xl border border-border bg-card p-6">
            <p class="text-sm text-muted-foreground">
              ¿Prefieres escribir?
              <a
                href="mailto:fmmpablo@gmail.com"
                class="ml-1 text-accent transition-colors hover:text-accent/80"
              >
                fmmpablo@gmail.com
              </a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8 lg:col-span-2">
          <!-- Social links -->
          <div>
            <h3 class="mb-4 font-mono text-[0.7rem] uppercase tracking-[0.2em] text-dim">
              Encuéntrame en
            </h3>
            <div class="space-y-2">
              {socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 rounded-lg border border-border bg-card px-4 py-3 text-sm text-muted-foreground transition-colors hover:border-accent/30 hover:bg-card-hover hover:text-accent"
                >
                  <span class="font-medium text-foreground">{link.label}</span>
                  <span class="ml-auto font-mono text-xs text-dim">↗</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Location -->
          <div>
            <h3 class="mb-4 font-mono text-[0.7rem] uppercase tracking-[0.2em] text-dim">
              Base
            </h3>
            <p class="text-sm text-muted-foreground">Madrid, España</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
