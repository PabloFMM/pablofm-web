---
import "@/styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  activeNav?: string;
}

const {
  title = "Pablo FM — Emprendedor y creador",
  description = "Construyo cosas que conectan personas. Emprendedor, cofundador de Videona, inversor y creador multidisciplinar.",
  canonicalPath = "",
  ogImage,
  activeNav,
} = Astro.props;

const siteUrl = "https://pablofm.com";
const canonical = `${siteUrl}${canonicalPath}`;
const resolvedOgImage = ogImage ?? `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts: Geist (loaded via @fontsource-variable in Layout frontmatter) -->

    <title>{title}</title>

    <!-- Umami Analytics — privacy-first, no cookies -->
    <script
      defer
      src="https://analytics.pablofm.com/script.js"
      data-website-id="3754d1da-a351-42a2-99da-c104b922d958"
    ></script>

    <slot name="head" />
  </head>
  <body class="relative overflow-x-hidden">
    <!-- MMO Starfield background -->
    <canvas
      id="starfield"
      class="pointer-events-none fixed inset-0 -z-10"
      aria-hidden="true"
    ></canvas>

    <Navigation activeNav={activeNav} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- Starfield script — MMO colors + alphaDir fade -->
    <script is:inline>
      (function () {
        const canvas = document.getElementById("starfield");
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        // MMO Rarity tiers — mantener colores
        const TIERS = [
          { color: "255,255,255", weight: 60, minR: 0.3, maxR: 1.2 },  // Common — blanco
          { color: "34,197,94",   weight: 25, minR: 0.5, maxR: 1.5 },  // Uncommon — verde
          { color: "59,130,246",  weight: 10, minR: 0.6, maxR: 1.8 },  // Rare — azul
          { color: "168,85,247",  weight: 4,  minR: 0.8, maxR: 2.5 },  // Epic — morado
          { color: "249,115,22",  weight: 1,  minR: 1.0, maxR: 3.0 },  // Legendary — naranja
        ];

        // Weighted pool
        const pool = [];
        TIERS.forEach((t, i) => { for (let w = 0; w < t.weight; w++) pool.push(i); });

        const STAR_COUNT = 175;
        let stars = [];
        let W = 0, H = 0;

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }

        function initStars() {
          stars = [];
          for (let i = 0; i < STAR_COUNT; i++) {
            const ti = pool[Math.floor(Math.random() * pool.length)];
            const t = TIERS[ti];
            stars.push({
              x: Math.random() * W,
              y: Math.random() * H,
              r: t.minR + Math.random() * (t.maxR - t.minR),
              alpha: Math.random(),
              alphaDir: Math.random() > 0.5 ? 1 : -1,
              speed: Math.random() * 0.004 + 0.002,
              vx: (Math.random() - 0.5) * 0.06,
              vy: (Math.random() - 0.5) * 0.06,
              tierIdx: ti,
            });
          }
        }

        function draw() {
          ctx.clearRect(0, 0, W, H);

          for (const s of stars) {
            // Movimiento suave
            s.x += s.vx;
            s.y += s.vy;
            if (s.x < -2) s.x = W + 2;
            if (s.x > W + 2) s.x = -2;
            if (s.y < -2) s.y = H + 2;
            if (s.y > H + 2) s.y = -2;

            // Fade in/out — sistema alphaDir de /velo
            s.alpha += s.alphaDir * s.speed;
            if (s.alpha > 0.85) { s.alpha = 0.85; s.alphaDir = -1; }
            if (s.alpha < 0.05) { s.alpha = 0.05; s.alphaDir = 1; }

            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${TIERS[s.tierIdx].color}, ${s.alpha})`;
            ctx.fill();
          }

          requestAnimationFrame(draw);
        }

        let resizeTimer;
        window.addEventListener("resize", () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => { resize(); initStars(); }, 200);
        });

        resize();
        initStars();
        draw();
      })();
    </script>
  </body>
</html>
