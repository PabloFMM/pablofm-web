---
import "@/styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  activeNav?: string;
}

const {
  title = "Pablo FM — Emprendedor y creador",
  description = "Construyo cosas que conectan personas. Emprendedor, cofundador de Videona, inversor y creador multidisciplinar.",
  canonicalPath = "",
  ogImage,
  activeNav,
} = Astro.props;

const siteUrl = "https://pablofm.com";
const canonical = `${siteUrl}${canonicalPath}`;
const resolvedOgImage = ogImage ?? `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts: Geist (loaded via @fontsource-variable in Layout frontmatter) -->

    <title>{title}</title>

    <!-- Umami Analytics — privacy-first, no cookies -->
    <script
      defer
      src="https://analytics.pablofm.com/script.js"
      data-website-id="3754d1da-a351-42a2-99da-c104b922d958"
    ></script>

    <slot name="head" />
  </head>
  <body class="relative overflow-x-hidden">
    <!-- MMO Starfield background -->
    <canvas
      id="starfield"
      class="pointer-events-none fixed inset-0 -z-20"
      aria-hidden="true"
    ></canvas>

    <!-- Subtle accent glow (ámbar/cobre) -->
    <div
      class="pointer-events-none fixed inset-0 -z-10 bg-accent-glow"
      aria-hidden="true"
    />

    <Navigation activeNav={activeNav} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- MMO Starfield script — requestAnimationFrame, zero dependencies -->
    <script>
      (function () {
        const canvas = document.getElementById("starfield") as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        // ── MMO rarity tiers ────────────────────────────────────────────────
        const TIERS = [
          // { color, weight, minSize, maxSize, glow }
          { color: "#E5E7EB", weight: 60, minSize: 0.6, maxSize: 1.4, glow: false },  // Common
          { color: "#22C55E", weight: 25, minSize: 0.8, maxSize: 1.8, glow: false },  // Uncommon
          { color: "#3B82F6", weight: 10, minSize: 1.0, maxSize: 2.2, glow: false },  // Rare
          { color: "#A855F7", weight: 4,  minSize: 1.5, maxSize: 3.0, glow: true  },  // Epic
          { color: "#F97316", weight: 1,  minSize: 2.0, maxSize: 4.0, glow: true  },  // Legendary
        ] as const;

        // Build weighted lookup table
        const pool: number[] = [];
        TIERS.forEach((t, i) => {
          for (let w = 0; w < t.weight; w++) pool.push(i);
        });

        interface Star {
          x: number;
          y: number;
          r: number;
          tierIdx: number;
          phase: number;      // twinkle phase offset (0–2π)
          speed: number;      // twinkle speed multiplier
          opacity: number;    // base opacity
          vx: number;         // drift velocity x
          vy: number;         // drift velocity y
        }

        const STAR_COUNT = 350;
        let stars: Star[] = [];
        let W = 0;
        let H = 0;
        let animId = 0;

        function resize() {
          W = canvas!.width = window.innerWidth;
          H = canvas!.height = window.innerHeight;
        }

        function pickTier(): number {
          return pool[Math.floor(Math.random() * pool.length)];
        }

        function initStars() {
          stars = [];
          for (let i = 0; i < STAR_COUNT; i++) {
            const ti = pickTier();
            const t = TIERS[ti];
            stars.push({
              x: Math.random() * W,
              y: Math.random() * H,
              r: t.minSize + Math.random() * (t.maxSize - t.minSize),
              tierIdx: ti,
              phase: Math.random() * Math.PI * 2,
              speed: 0.3 + Math.random() * 0.7,
              opacity: 0.5 + Math.random() * 0.5,
              vx: (Math.random() - 0.5) * 0.08,
              vy: (Math.random() - 0.5) * 0.08,
            });
          }
        }

        function draw(ts: number) {
          ctx!.clearRect(0, 0, W, H);

          const t = ts * 0.001; // seconds

          for (const star of stars) {
            // Smooth drift movement
            star.x += star.vx;
            star.y += star.vy;
            // Wrap around edges
            if (star.x < -4) star.x = W + 4;
            if (star.x > W + 4) star.x = -4;
            if (star.y < -4) star.y = H + 4;
            if (star.y > H + 4) star.y = -4;

            const tier = TIERS[star.tierIdx];
            // Twinkle: smooth sine wave
            const twinkle = 0.4 + 0.6 * (0.5 + 0.5 * Math.sin(t * star.speed + star.phase));
            const alpha = star.opacity * twinkle;

            ctx!.save();
            ctx!.globalAlpha = alpha;

            if (tier.glow) {
              // Epic / Legendary — radial glow
              const glowR = star.r * 3.5;
              const grad = ctx!.createRadialGradient(star.x, star.y, 0, star.x, star.y, glowR);
              grad.addColorStop(0, tier.color);
              grad.addColorStop(0.35, tier.color + "88");
              grad.addColorStop(1, tier.color + "00");
              ctx!.fillStyle = grad;
              ctx!.beginPath();
              ctx!.arc(star.x, star.y, glowR, 0, Math.PI * 2);
              ctx!.fill();
            }

            // Core dot
            ctx!.fillStyle = tier.color;
            ctx!.beginPath();
            ctx!.arc(star.x, star.y, star.r, 0, Math.PI * 2);
            ctx!.fill();

            ctx!.restore();
          }

          animId = requestAnimationFrame(draw);
        }

        function start() {
          if (animId) cancelAnimationFrame(animId);
          resize();
          initStars();
          animId = requestAnimationFrame(draw);
        }

        // Debounced resize
        let resizeTimer: ReturnType<typeof setTimeout>;
        window.addEventListener("resize", () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(start, 200);
        });

        start();
      })();
    </script>
  </body>
</html>
