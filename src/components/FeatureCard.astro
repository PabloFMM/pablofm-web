---
interface Props {
  title: string;
  description: string;
  iconBg?: string;
}

const { title, description, iconBg = "bg-accent/10" } = Astro.props;
---

<div class="rounded-lg border border-border bg-card p-6 transition-colors hover:bg-card-hover">
  <div class:list={["mb-4 flex h-10 w-10 items-center justify-center rounded-lg text-accent", iconBg]}>
    <slot name="icon" />
  </div>
  <h3 class="text-base font-semibold text-foreground">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{description}</p>
</div>
