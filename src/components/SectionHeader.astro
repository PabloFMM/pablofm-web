---
interface Props {
  label: string;
  title: string;
  description?: string;
}

const { label, title, description } = Astro.props;
---

<div class="mb-8">
  <span class="font-mono text-[0.7rem] font-medium uppercase tracking-[0.25em] text-accent">
    {label}
  </span>
  <h2 class="mt-3 font-display text-3xl tracking-tight text-foreground sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
      {description}
    </p>
  )}
</div>
