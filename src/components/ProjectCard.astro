---
interface Props {
  title: string;
  description: string;
  role: string;
  href?: string;
  tags?: string[];
  status?: "active" | "past" | "upcoming";
}

const { title, description, role, href, tags = [], status = "active" } = Astro.props;

const statusStyles = {
  active: "bg-green/10 text-green",
  past: "bg-muted text-muted-foreground",
  upcoming: "bg-accent/10 text-accent",
};

const statusLabels = {
  active: "Activo",
  past: "Pasado",
  upcoming: "Próximamente",
};
---

<article class="group rounded-lg border border-border bg-card p-6 transition-all hover:border-border/80 hover:bg-card-hover">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="mb-3 flex items-center gap-2">
        <span class:list={["inline-flex rounded-full px-2 py-0.5 font-mono text-[0.65rem] font-medium", statusStyles[status]]}>
          {statusLabels[status]}
        </span>
      </div>

      {href ? (
        <a href={href} target="_blank" rel="noopener noreferrer" class="block">
          <h3 class="font-display text-xl text-foreground transition-colors group-hover:text-accent">
            {title}
          </h3>
        </a>
      ) : (
        <h3 class="font-display text-xl text-foreground">
          {title}
        </h3>
      )}

      <p class="mt-1 font-mono text-xs text-dim">{role}</p>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{description}</p>

      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="rounded-full border border-border bg-background px-2.5 py-0.5 font-mono text-[0.6rem] text-dim">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>
